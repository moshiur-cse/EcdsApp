                        layerName = items.layerName;

                        jQuery("#map_2_columnList_" + items.layerId).empty();

                        if (items.layerTypeId == 4) {

                            path = items.boundaryPath;
                            g_filepath = path;
                            g_mainAtt = items.boundaryGeoCodeColumnName;

                            var columnBindId = "map2_columnList_" + items.layerId;

                            var tableId = items.tableId;
                            getTableColumnList(tableId, columnBindId);


                            jQuery("#" + columnBindId).change(function () {
                                var columnName = jQuery("#" + columnBindId).val();

                                getUserDefinedColor(items.layerId, layerId, items.layerName + " (" + jQuery('#'+columnBindId+' option:selected').text()+")");


                                jQuery.ajax({
                                    url: getMapBindData(tableId, columnName, items.boundaryId, layerId),
                                    success: function () {
                                        LayerShowHide(items.layerId, layerId, path, items.mainAttDisName, items.boundaryGeoNameColumnName, items.boundaryGeoCodeColumnName, items.cLat, items.cLong, items.layerName, items.layerTypeId, items.isLegendColor, items.legendcolorField, admin_code_list, items.lineOpacity, items.fillOpacity, items.lineWeight, items.lineColorCode, items.boundaryId, items.tableId);

                                    },
                                    error: function (ex, status, error) {
                                        window.Swal.fire({
                                            icon: "error",
                                            title: "Failed to load Shape file. " + ex.responseText,
                                            showConfirmButton: false, //true
                                            timer: 3000   // remove timer
                                        });
                                    }
                                });


                            });

                        }
                        else {
                            jQuery.ajax({
                                url: getUserDefinedColor(items.layerId, layerId, items.layerName),
                                success: function () {
                                        LayerShowHide(items.layerId, layerId, path, items.mainAttDisName, items.mainAtt, items.mainAttCode, items.cLat, items.cLong, items.layerName, items.layerTypeId, items.isLegendColor, items.legendcolorField, admin_code_list, items.lineOpacity, items.fillOpacity, items.lineWeight, items.lineColorCode, items.boundaryId, items.tableId);
                                }
                                ,
                                error: function (ex, status, error) {
                                    window.Swal.fire({
                                        icon: "error",
                                        title: "Failed to load Shape file. " + ex.responseText,
                                        showConfirmButton: false, //true
                                        timer: 3000   // remove timer
                                    });
                                }
                            });

                            //LayerShowHide(items.layerId, layerId, path, items.mainAttDisName, items.mainAtt, items.mainAttCode, items.cLat, items.cLong, items.firstAttDisName, items.firstAtt, items.layerName, items.layerTypeId, items.isLegendColor, items.legendcolorField, admin_code_list, opacity, fillOpacity, weight, color, items.boundaryId, items.tableId);
                        }
                    },
                    error: function (ex, status, error) {
                        window.Swal.fire({
                            icon: "error",
                            title: "Failed to load Shape file. " + ex.responseText,
                            showConfirmButton: false, //true
                            timer: 3000   // remove timer
                        });
                    },
