        function map2_LayerShowHide(layerUid, layerId, filepath, mainAttDisName, mainAtt, attCode, cLat, cLong, layerName, layerTypeId, isLegendColor, legendcolorField, admin_code_list, opacity, fillOpacity, weight, color, boundaryId, tableId) {
            map2_active_layer = layerId;
            var layerPath = "../assets/js/map/map_data/" + filepath;


            if (secondMap.hasLayer(map2_data_layer[layerId])) {
                secondMap.removeLayer(map2_data_layer[layerId]);
                secondMap.removeLayer(map2_legend);
                $("p." + layerId).remove();
                $("#map_layer_" + layerId).remove();
                //secondMap.removeLayer(mapLabels);
                // mapLabels = L.layerGroup();
            }


            map2_data_layer[layerId] = L.geoJson(null, {
                style: style,
                onEachFeature: onEachFeature,
            });


            $.getJSON(layerPath, function(LayerInfo) {
                if (!LayerInfo) return;

                map2_data_layer[layerId].addData(LayerInfo);
                layerData = LayerInfo;

            }).done(function(e) {
                secondMap.addLayer(map2_data_layer[layerId]);



                if (isLegendColor == 1) {
                    map2_legendAndInfo(e, mainAtt, attCode, layerId, layerName, isLegendColor, legendcolorField);
                }



            });


            function style(feature) {

                if (admin_code_list.length > 0 && (admin_code_list.includes(feature.properties[attCode].toString()) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 2)) ||
                    admin_code_list.includes(feature.properties[attCode].toString().substr(0, 4)) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 8)) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 13)))) {

                    return {
                        fillColor: isLegendColor == 0 ? '#0000ffff' : map2_getColor(layerId, map2_mapBindData[layerId][feature.properties[attCode]].get('value')),
                        weight: weight,
                        opacity: opacity,
                        color: color,
                        //dashArray: '1',
                        fillOpacity: fillOpacity
                    };


                } else if (admin_code_list.length == 0 && layerTypeId == 4) {

                    var tDataColor = map2_getColor(layerId, map2_mapBindData[layerId][feature.properties[attCode]].get('value'));

                    //console.log(map2_mapBindData["exposure"]['10040009'].get('value'));
                    return {

                        fillColor: isLegendColor == 0 ? '#ffffff00' : tDataColor,
                        weight: weight,
                        opacity: opacity,
                        color: tDataColor,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }

                else if (isLegendColor == 1 && layerTypeId == 3) {

                    var uColor = map2_getColor(layerId, feature.properties[legendcolorField]);
                    return {
                        fillColor: uColor,
                        weight: weight,
                        opacity: opacity,
                        color: uColor,
                        /* dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
                else {
                    //alert(color);
                    return {
                        fillColor: '#ffffff00',
                        weight: weight,
                        opacity: opacity,
                        /* transparent: true,*/
                        color: color,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
            }
            function onEachFeature(feature, layer) {

                layer.on({
                    mouseover: highlightFeature,
                    mouseout: resetHighlight,

                });


                //}




                //if (cLat != null || cLong != null) {
                //    mapLabelShowHide(feature, layer, layerId, mainAtt, cLat, cLong);
                //}

            }


            function highlightFeature(e) {
                var layer = e.target;
                var popupContent = "";
                if (layerTypeId == 4) {

                    var mainContent = '';
                    for (var i = 0; i < Object.getOwnPropertyNames(layer.feature.properties).length; i++) {
