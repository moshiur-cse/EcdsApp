                    jQuery("p." + layerId).remove();
                    jQuery("#map_layer_" + layerId).remove();
                    //secondMap.removeLayer(mapLabels);
                    //mapLabels = L.layerGroup();

                    delete mapBindData[layerId];
                    delete userDefinedColorList[layerId];
                    delete data_layer[layerId];
                    delete data_layer_details[layerId];
                }

                //layerId
            }


        });


        function map1_LayerShowHide(layerUid, layerId, filepath, mainAttDisName, mainAtt, attCode, cLat, cLong, layerName, layerTypeId, isLegendColor, map1_legendcolorField, admin_code_list, opacity, fillOpacity, weight, color, boundaryId, tableId) {


            var layerPath = "../assets/js/map/map_data/" + filepath;

            if (firstMap.hasLayer(map1_data_layer[layerId])) {
                firstMap.removeLayer(map1_data_layer[layerId]);
                firstMap.removeLayer(map1_legend);
                $("p." + layerId).remove();
                $("#map_layer_" + layerId).remove();
                //firstMap.removeLayer(mapLabels);
                //mapLabels = L.layerGroup();
            }


            map1_data_layer[layerId] = L.geoJson(null, {
                style: style,
                onEachFeature: onEachFeature,
            });


            $.getJSON(layerPath, function (LayerInfo) {
                if (!LayerInfo) return;

                map1_data_layer[layerId].addData(LayerInfo);
                layerData = LayerInfo;
                /*console.log(layerData);*/

            }).done(function (e) {
                firstMap.addLayer(map1_data_layer[layerId]);

                if (isLegendColor == 1) {
                    map1_legendAndInfo(e, mainAtt, attCode, layerId, layerName, isLegendColor, map1_legendcolorField);
                }



            });


            function style(feature) {


                if (admin_code_list.includes(feature.properties[attCode].toString()) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 2)) ||
                    admin_code_list.includes(feature.properties[attCode].toString().substr(0, 4)) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 8)) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 13))) {

                    //colorList[feature.properties[attCode]] = getRandomColor();
                    //map1_mapBindData[layerId][feature.properties[attCode]].get('code')
                    return {

                        fillColor: isLegendColor == 0 ? '#0000ffff' : map1_getColor(layerId, map1_mapBindData[layerId][feature.properties[attCode]].get('value')),
                        weight: weight,
                        opacity: opacity,
                        color: color,
                        //dashArray: '1',
                        fillOpacity: fillOpacity
                    };


                } else if (admin_code_list.length == 0 && layerTypeId == 4) {
                    var tDataColor = map1_getColor(layerId, map1_mapBindData[layerId][feature.properties[attCode]].get('value'));
                    return {
                        fillColor: isLegendColor == 0 ? '#ffffff00' : tDataColor,
                        weight: weight,
                        opacity: opacity,
                        color: tDataColor,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }

                else if (isLegendColor == 1 && layerTypeId == 3) {
                    var uColor = map1_getColor(layerId, feature.properties[map1_legendcolorField]);
                    return {
                        fillColor: uColor,
                        weight: weight,
                        opacity: opacity,
                        color: uColor,
                        /* dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
                else {
                    return {
                        fillColor: '#ffffff00',
                        weight: weight,
                        opacity: opacity,
                        color: color,
                        fillOpacity: fillOpacity
                    };
                }
            }
            function onEachFeature(feature, layer) {
                layer.on({
                    mouseover: highlightFeature,
                    mouseout: resetHighlight,
                });
            }


            function highlightFeature(e) {
                var layer = e.target;


                var popupContent = "";
                if (layerTypeId == 4) {



                    popupContent = '<div style="width:300px;text-align:center;"><p>' + layer.feature.properties[mainAtt] + " : " + map1_mapBindData[layerId][layer.feature.properties[attCode]].get('value') + '</p></div>';
                } else {
                    var mainContent = '';
                    for (var i = 0; i < Object.getOwnPropertyNames(layer.feature.properties).length; i++) {
                        if (Object.getOwnPropertyNames(layer.feature.properties)[i] == "CntLat" || Object.getOwnPropertyNames(layer.feature.properties)[i] == "CntLong") {
                            continue;
                        }

                        mainContent += '<p>' + Object.getOwnPropertyNames(layer.feature.properties)[i] + " : " + layer.feature.properties[Object.getOwnPropertyNames(layer.feature.properties)[i]] + '</p>';
                    }

                    //popupContent = '<div style="width:300px;text-align:center;"><p>' + mainAttDisName + " : " + layer.feature.properties[mainAtt] + '</p>' + ((firstAtt != null) ? '<p>' + (firstAttDisName + " : " + layer.feature.properties[firstAtt]) + '</p>' : " ") + '</div>';
                    popupContent = '<div style="min-width:200px;text-align:center;">' + mainContent + '</div>';

                }

                layer.bindPopup(popupContent).openPopup(e.latlng);

                //layer.setStyle({
                //    //weight: 2,
                //    //color: '#E11F21',
                //    dashArray: '',
                //    //fillOpacity: 0.4
                //}).bindPopup(popupContent).openPopup(e.latlng);

                //if (!L.Browser.ie && !L.Browser.opera && !L.Browser.edge) {
                //    layer.bringToFront();
                //}
            }
            function resetHighlight(e) {
                firstMap.closePopup();
                //map1_data_layer[layerId].resetStyle(e.target);
            }

            /*console.log(map1_data_layer[layerId]);*/
        }
        function map1_getUserDefinedColor(layerUid, layerId,LegendName) {


            map1_userDefinedColorList[layerId] = {};
            var colorList = [];

            jQuery.ajax({
                type: "POST",
                url: "@Url.Action("GetUserDefinedLegendInfo")",
                dataType: "json",
                data: { layer_id: layerUid },
                before: jQuery("#busy-indicator").fadeIn(150),
                success: function (items) {

                    $.each(items,
                        function (i, item) {
                            colorList[i] = new Map([["map1_legendName", LegendName],["color", item.colorCode], ["value", item.attCode], ["name", item.attName]]);
                        });
                    map1_userDefinedColorList[layerId] = colorList;



                },
                error: function (ex, status, error) {
                    //msg.init("error",
                    //    "Error... . . !",
                    //    "Failed to load Shape file. " + ex.responseText);

                    window.Swal.fire({
                        icon: "error",
                        title: "Failed to load Shape file. " + ex.responseText,
                        showConfirmButton: false, //true
                        timer: 3000   // remove timer
                    });
                },
                complete: jQuery("#busy-indicator").fadeOut(150)
            });



        }
        function map1_getTableColumnList(tableId, columnBindId) {
        var $data = $("#" + columnBindId);

             jQuery.ajax({
                    type: "POST",
                    url: "@Url.Action("GetTbleColumnList")",
                    dataType: "json",
                    data: { tableId: tableId },
                    before: jQuery("#busy-indicator").fadeIn(150),
                    success: function (datas) {

                        $data.append(
                    '<option value="" selected="selected">----- Select -----</option>');
                $.each(datas,
                    function (i, item) {
                        $("<option />").val(item.value).html(item.text).appendTo($data);
                    });

                    },
                    error: function(ex, status, error) {
                        //msg.init("error",
                        //    "Error... . . !",
                        //    "Failed to load Shape file. " + ex.responseText);
                    },
                 complete: jQuery("#busy-indicator").fadeOut(150)
             });

        }
        function map1_getMapBindData(tableId, columnName, boundaryId, layerId) {
        map1_mapBindData[layerId] = {};
        var dataList = {};
            jQuery.ajax({
                    type: "POST",
                    url: "@Url.Action("GetMapBindData")",
                    dataType: "json",
                data: { tableId: tableId, columnName: columnName, boundaryId: boundaryId },
                    before: jQuery("#busy-indicator").fadeIn(150),
                success: function (items) {

                    $.each(items, function (i, item) {
                        dataList[item.code] = new Map([["code", item.code], ["value", item.value]]);
                    });

