                    url: "@Url.Action("GetLayerInformation")",
                    dataType: "json",
                    data: { layer_id: jQuery("#" + this.id).val() },
                    before: jQuery("#busy-indicator").fadeIn(150),
                    success: function (items) {

                        if (items.isLegendColor == 1) {
                            getUserDefinedColor(items.layerId, layerId, items.layerName);
                        }


                        path = items.themePath + "/" + items.subThemePath + "/" + items.layerPath + "/" + items.layerFileName;

