                        if (items.isLegendColor == 1) {
                            map1_getUserDefinedColor(items.layerId, layerId, items.layerName);
                        }


                        path = items.themePath + "/" + items.subThemePath + "/" + items.layerPath + "/" + items.layerFileName;

                        layerUid = items.layerId;
                        layerName = items.layerName;

                        jQuery("#map_1_columnList_" + items.layerId).empty();
                        if (items.layerTypeId == 4) {

                            path = items.boundaryPath;
                            g_filepath = path;
                            g_mainAtt = items.boundaryGeoCodeColumnName;

                            var columnBindId = "map1_columnList_" + items.layerId;

                            var tableId = items.tableId;
                            map1_getTableColumnList(tableId, columnBindId);


                            jQuery("#" + columnBindId).change(function () {
                                var columnName = jQuery("#" + columnBindId).val();

                                map1_getUserDefinedColor(items.layerId, layerId, items.layerName + " (" + jQuery('#'+columnBindId+' option:selected').text()+")");


                                jQuery.ajax({
                                    url: map1_getMapBindData(tableId, columnName, items.boundaryId, layerId),
                                    success: function () {
                                        map1_LayerShowHide(items.layerId, layerId, path, items.mainAttDisName, items.boundaryGeoNameColumnName, items.boundaryGeoCodeColumnName, items.cLat, items.cLong, items.layerName, items.layerTypeId, items.isLegendColor, items.map1_legendcolorField, admin_code_list, items.lineOpacity, items.fillOpacity, items.lineWeight, items.lineColorCode, items.boundaryId, items.tableId);

                                    },
                                    error: function (ex, status, error) {
                                        window.Swal.fire({
                                            icon: "error",
                                            title: "Failed to load Shape file. " + ex.responseText,
                                            showConfirmButton: false, //true
                                            timer: 3000   // remove timer
                                        });
                                    }
                                });


                            });

                        }
                        else {
                            jQuery.ajax({
                                url: map1_getUserDefinedColor(items.layerId, layerId, items.layerName),
                                success: function () {
                                        map1_LayerShowHide(items.layerId, layerId, path, items.mainAttDisName, items.mainAtt, items.mainAttCode, items.cLat, items.cLong, items.layerName, items.layerTypeId, items.isLegendColor, items.map1_legendcolorField, admin_code_list, items.lineOpacity, items.fillOpacity, items.lineWeight, items.lineColorCode, items.boundaryId, items.tableId);
                                }
                                ,
                                error: function (ex, status, error) {
                                    window.Swal.fire({
                                        icon: "error",
                                        title: "Failed to load Shape file. " + ex.responseText,
                                        showConfirmButton: false, //true
                                        timer: 3000   // remove timer
                                    });
                                }
                            });

                            //map1_LayerShowHide(items.layerId, layerId, path, items.mainAttDisName, items.mainAtt, items.mainAttCode, items.cLat, items.cLong, items.firstAttDisName, items.firstAtt, items.layerName, items.layerTypeId, items.isLegendColor, items.map1_legendcolorField, admin_code_list, opacity, fillOpacity, weight, color, items.boundaryId, items.tableId);
                        }
                    },
                    error: function (ex, status, error) {
                        window.Swal.fire({
                            icon: "error",
                            title: "Failed to load Shape file. " + ex.responseText,
                            showConfirmButton: false, //true
                            timer: 3000   // remove timer
                        });
                    },
                    complete: function () {
                        jQuery("#busy-indicator").fadeOut(150)
                    }
                });
                 }
            else {
                if (firstMap.hasLayer(map1_data_layer[layerId])) {
                    firstMap.removeLayer(map1_data_layer[layerId]);
                    firstMap.removeLayer(map1_legend);
                    jQuery("p." + layerId).remove();
                    jQuery("#map_layer_" + layerId).remove();
                    //firstMap.removeLayer(mapLabels);
                    //mapLabels = L.layerGroup();

                    delete map1_mapBindData[layerId];
                    delete map1_userDefinedColorList[layerId];
                    delete map1_data_layer[layerId];
                    delete map1_data_layer_details[layerId];
                }

                //layerId
            }


        });
        jQuery('.map2_layer_class').click(function ($) {
            var layerId = this.id;
            if (jQuery("#" + layerId).prop("checked") == true) {
