
@{
    ViewData["Title"] = "Map Comparison";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles{
    <!-- leaflet Css -->
    <link href="~/assets/libs/leaflet/leaflet.css" rel="stylesheet" type="text/css" />
    <link href="~/assets/css/mapstyle.css" rel="stylesheet" />

    <style>
        .map_btns_content {
            z-index: 1000;
            position: absolute;
            left: 45%;
            /*right: 50%;*/
            /*width: 50px;
        height: auto;*/
            margin: 0;
            padding: 0;
            text-align: right;
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
        }
        .map1_legend_info {
            padding: 1px;
            background: rgba(255,255,255,0.8);
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
            border-radius: 5px;
            /*font-size: 1vw;*/
            font: 400 14px/1.0 Roboto, Helvetica, Arial, sans-serif;
            overflow: scroll;
            min-height: 100px;
            max-height: 400px;
            max-width: 300px;
            resize: both;
        }

            .map1_legend_info i {
                /* width: 1.5vw;
                height: 1.5vw;*/
                width: 20px;
                height: 15px;
                float: left;
                /*margin-right: 1vw;*/
                margin-right: 10px;
                opacity: 0.7;
                /*font-size: 1vw;*/
                font: 400 14px/1.0 Roboto, Helvetica, Arial, sans-serif;
            }

            .map1_legend_info p {
                padding: 0.2vw;
            }
    </style>
}

<div>

    <partial name="_CompareMapModals" />


    <div id="map_btns_content" class="map_btns_content">
        <div id="filter_option" class="map_btns btn_map_layers" data-bs-toggle="modal" data-bs-target="#exampleModalScrollable" title="Add Map Layer"></div>
        @*<div id="map_layer" class="map_btns right-bar-toggle waves-effect" title="Map Filtering"> </div>*@
        @*<div id="map_bg_layers" class="map_btns btn_map_bglayers" title="Select the Map Background Layer"></div>*@
        <div id="map_reset" class="map_btns map_reset" onclick="map_reset()" title="Reset Map"> </div>
        <div id="map_center" class="map_btns btn_full_extent" title="Full extent the map"> </div>
        @*<div class="map_btns" title="Show or Hide Map Label"><input type="checkbox" id="map_label"></div>*@
        @*<div id="map_download" class="map_btns btn_map_download" title="Download" onclick="downloadMap('');"> </div>*@
    </div>

    <div class="row">
        <div class="col-md-6">
            <div id="first-map" class="leaflet-map page-content"></div>
        </div>
        <div class="col-md-6">
            <div id="second-map" class="leaflet-map page-content"></div>
        </div>
    </div>
</div>

