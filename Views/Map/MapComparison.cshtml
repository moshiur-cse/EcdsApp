        function LayerShowHide(layerUid, layerId, filepath, mainAttDisName, mainAtt, attCode, cLat, cLong, layerName, layerTypeId, isLegendColor, legendcolorField, admin_code_list, opacity, fillOpacity, weight, color, boundaryId, tableId) {

            var layerPath = "../assets/js/map/map_data/" + filepath;


            if (secondMap.hasLayer(data_layer[layerId])) {
                secondMap.removeLayer(data_layer[layerId]);
                secondMap.removeLayer(legend);
                $("p." + layerId).remove();
                $("#map_layer_" + layerId).remove();
                //secondMap.removeLayer(mapLabels);
               // mapLabels = L.layerGroup();
            }


            data_layer[layerId] = L.geoJson(null, {
                style: style,
                onEachFeature: onEachFeature,
            });


            $.getJSON(layerPath, function (LayerInfo) {
                if (!LayerInfo) return;

                data_layer[layerId].addData(LayerInfo);
                layerData = LayerInfo;

            }).done(function (e) {
                secondMap.addLayer(data_layer[layerId]);



                if (isLegendColor == 1) {
                    legendAndInfo(e, mainAtt, attCode, layerId, layerName, isLegendColor, legendcolorField);
                }



            });


            function style(feature) {

                if (admin_code_list.includes(feature.properties[attCode].toString()) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 2)) ||
                    admin_code_list.includes(feature.properties[attCode].toString().substr(0, 4)) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 8)) || admin_code_list.includes(feature.properties[attCode].toString().substr(0, 13))) {

                    return {
                        fillColor: isLegendColor == 0 ? '#0000ffff' : getColor(layerId, mapBindData[layerId][feature.properties[attCode]].get('value')),
                        weight: weight,
                        opacity: opacity,
                        color: color,
                        //dashArray: '1',
                        fillOpacity: fillOpacity
                    };


                } else if (admin_code_list.length == 0 && layerTypeId == 4) {

                    var tDataColor = getColor(layerId, mapBindData[layerId][feature.properties[attCode]].get('value'));

                    //console.log(mapBindData["exposure"]['10040009'].get('value'));
                    return {

                        fillColor: isLegendColor == 0 ? '#ffffff00' : tDataColor,
                        weight: weight,
                        opacity: opacity,
                        color: tDataColor,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }

                else if (isLegendColor == 1 && layerTypeId == 3) {

                    var uColor = getColor(layerId, feature.properties[legendcolorField]);
                    return {
                        fillColor: uColor,
                        weight: weight,
                        opacity: opacity,
                        color: uColor,
                        /* dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
                else {
                    //alert(color);
                    return {
                        fillColor: '#ffffff00',
                        weight: weight,
                        opacity: opacity,
                        /* transparent: true,*/
                        color: color,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
            }
            function onEachFeature(feature, layer) {

                layer.on({
                    mouseover: highlightFeature,
                    mouseout: resetHighlight,
                  
                });


                //}




                if (cLat != null || cLong != null) {
                    mapLabelShowHide(feature, layer, layerId, mainAtt, cLat, cLong);
                }

            }


            function highlightFeature(e) {
                var layer = e.target;


                var popupContent = "";
                if (layerTypeId == 4) {



                    popupContent = '<div style="width:300px;text-align:center;"><p>' + layer.feature.properties[mainAtt] + " : " + mapBindData[layerId][layer.feature.properties[attCode]].get('value') + '</p></div>';
                } else {
                    var mainContent = '';
                    for (var i = 0; i < Object.getOwnPropertyNames(layer.feature.properties).length; i++) {
                        if (Object.getOwnPropertyNames(layer.feature.properties)[i] == "CntLat" || Object.getOwnPropertyNames(layer.feature.properties)[i] == "CntLong") {
                            continue;
                        }

                        mainContent += '<p>' + Object.getOwnPropertyNames(layer.feature.properties)[i] + " : " + layer.feature.properties[Object.getOwnPropertyNames(layer.feature.properties)[i]] + '</p>';
                    }

                    //popupContent = '<div style="width:300px;text-align:center;"><p>' + mainAttDisName + " : " + layer.feature.properties[mainAtt] + '</p>' + ((firstAtt != null) ? '<p>' + (firstAttDisName + " : " + layer.feature.properties[firstAtt]) + '</p>' : " ") + '</div>';
                    popupContent = '<div style="min-width:200px;text-align:center;">' + mainContent + '</div>';

                }

                layer.bindPopup(popupContent).openPopup(e.latlng);

            }
            function resetHighlight(e) {
                secondMap.closePopup();
            }

        }
        function getUserDefinedColor(layerUid, layerId,LegendName) {


            userDefinedColorList[layerId] = {};
            var colorList = [];

            jQuery.ajax({
