            secondMap.setView([23.837777, 90.347777], 7.0);
            L.tileLayer("", { attribution: mapAttrib }).addTo(secondMap);
            L.control.scale().addTo(secondMap);
            L.control.zoom({ position: 'bottomleft' }).addTo(secondMap);


            $("#map_center").on("click",
                function(e) {
                    firstMap.setView([23.737777, 90.537777], 7.0);
                    secondMap.setView([23.737777, 90.537777], 7.0);
                });


            $(".leaflet-control-zoom-in").on('click', function() {
                firstMap.zoomIn();
                secondMap.zoomIn();
            });
            $(".leaflet-control-zoom-out").on('click', function() {
                firstMap.zoomOut();
                secondMap.zoomOut();
            });


            firstMap.on('zoomend', function() {
                var zoomLavel = firstMap.getZoom();
                if (firstMap.getZoom() == 7) {
                    firstMap.setView([23.737777, 90.537777], 7.0);
                    secondMap.setView([23.737777, 90.537777], 7.0);

                } else {
                    zoomLavel = firstMap.getZoom();
                    firstMap.setView([23.737777, 90.537777], zoomLavel);
                    secondMap.setView([23.737777, 90.537777], zoomLavel);
                }
            });
