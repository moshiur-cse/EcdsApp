@{
    ViewData["Title"] = "Map Comparison";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles{
    <!-- leaflet Css -->
    <link href="~/assets/libs/leaflet/leaflet.css" rel="stylesheet" type="text/css" />
    <link href="~/assets/css/mapstyle.css" rel="stylesheet" />

    <style>

        #first-map, #second-map {
            height: 600px;
        }

        .map1_legend_info, .map2_legend_info {
            padding: 1px;
            background: rgba(255,255,255,0.8);
            box-shadow: 0 0 15px rgba(0,0,0,0.2);
            border-radius: 5px;
            /*font-size: 1vw;*/
            font: 400 14px/1.0 Roboto, Helvetica, Arial, sans-serif;
            overflow: auto;
            /* min-height: 100px;*/
            max-height: 400px;
            max-width: 300px;
            resize: both;
        }

            .map1_legend_info i, .map2_legend_info i {
                /* width: 1.5vw;
                            height: 1.5vw;*/
                width: 20px;
                height: 15px;
                float: left;
                /*margin-right: 1vw;*/
                margin-right: 10px;
                opacity: 0.7;
                /*font-size: 1vw;*/
                font: 400 14px/1.0 Roboto, Helvetica, Arial, sans-serif;
            }

            .map1_legend_info p, .map2_legend_info p {
                padding: 0.2vw;
            }

        .legendTitle {
            background: rgb(16 80 12);
            color: white;
            text-align: center
        }
    </style>
}



