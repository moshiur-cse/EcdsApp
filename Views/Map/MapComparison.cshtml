        function map1_getColor(layerId, d) {

            //console.log(map1_userDefinedColorList["main_river"][0].get('color'));


            for (var i = 0; i < map1_userDefinedColorList[layerId].length; i++) {

                if (map1_userDefinedColorList[layerId].length == 1) {
                    return map1_userDefinedColorList[layerId][0].get('color');

                }

                if (d >= map1_userDefinedColorList[layerId][i].get('value') && d < map1_userDefinedColorList[layerId][i + 1].get('value')) {
                    return map1_userDefinedColorList[layerId][i].get('color');
                }

                else if (d >= map1_userDefinedColorList[layerId][map1_userDefinedColorList[layerId].length - 1].get('value')) {
                    return map1_userDefinedColorList[layerId][map1_userDefinedColorList[layerId].length - 1].get('color');

                }
            }
        }
