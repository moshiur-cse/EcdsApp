                    zoom: 6.0,
                    layers: [L.tileLayer(osmUrl, { id: 'MapID', minZoom: 0, maxZoom: 25, attribution: mapAttrib })],

                });
            secondMap.setView([23.837777, 90.347777], 7.0);
            L.tileLayer("", { attribution: mapAttrib }).addTo(secondMap);
            L.control.scale().addTo(secondMap);
            L.control.zoom({ position: 'bottomleft' }).addTo(secondMap);


            $("#map_center").on("click",
                function (e) {
                    firstMap.setView([23.737777, 90.537777], 7.0);
                    secondMap.setView([23.737777, 90.537777], 7.0);
