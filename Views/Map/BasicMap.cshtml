        //Get Random Color
        function getRandomColor() {
            var letters = '0123456789ABCDEF';

            var color = '#';
            for (var i = 0; i < 6; i++) {
                color += letters[Math.floor(Math.random() * 16)];
            }
            return color;
        }

        //Get User Defined Color
    function getColor(layerId, d) {

        //console.log(userDefinedColorList["main_river"][0].get('color'));


        for (var i = 0; i < userDefinedColorList[layerId].length; i++) {

            if (userDefinedColorList[layerId].length == 1) {
                return userDefinedColorList[layerId][0].get('color');

            }

                if (d >= userDefinedColorList[layerId][i].get('value') && d < userDefinedColorList[layerId][i + 1].get('value')) {
                    return userDefinedColorList[layerId][i].get('color');
                }

                else if (d >= userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('value')) {
                    return userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('color');

                }
            }
        }


        //Set User Defined Color and Legend Name
        function getUserDefinedColor(layerUid, layerId,LegendName) {


            userDefinedColorList[layerId] = {};
            var colorList = [];

            jQuery.ajax({
                type: "POST",
                url: "@Url.Action("GetUserDefinedLegendInfo")",
                dataType: "json",
                data: { layer_id: layerUid },
                before: jQuery("#busy-indicator").fadeIn(150),
                success: function (items) {

                    $.each(items,
                        function (i, item) {
                            colorList[i] = new Map([["legendName", LegendName],["color", item.colorCode], ["value", item.attCode], ["name", item.attName]]);
                        });
                    userDefinedColorList[layerId] = colorList;



                },
                error: function (ex, status, error) {
                    //msg.init("error",
                    //    "Error... . . !",
                    //    "Failed to load Shape file. " + ex.responseText);

                    window.Swal.fire({
                        icon: "error",
                        title: "Failed to load Shape file. " + ex.responseText,
                        showConfirmButton: false, //true
                        timer: 3000   // remove timer
                    });
                },
                complete: jQuery("#busy-indicator").fadeOut(150)
            });



        }



