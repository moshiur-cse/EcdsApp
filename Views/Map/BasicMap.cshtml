        jQuery("#DistCode").on("change",function (evt, adop) {
                var distCode = $("#DistCode").val(),
                    $upazila = $("#UpazCode");
                    codeValue = distCode;

                $upazila.empty();


                if (!distCode) {
                    mapAttribute(admin, cLat, cLong, mapZoom, codeValue);
                    return false;
                }


                for (var i = 0; i < indexLenght; i++) {
                    if (boundary.features[i].properties.dist_code == distCode) {
                        mapAttribute(admin, boundary.features[i].properties.CNT_LAT, boundary.features[i].properties.CNT_LONG, 9, distCode);
                        mapZoom = 9;
                        cLat = boundary.features[i].properties.CNT_LAT;
                        cLong = boundary.features[i].properties.CNT_LONG;
                        //mapHighLighter();
                        break;
                    }
                }


                $.ajax({
                    type: "POST",
                    url: "@Url.Action("GetUpazilaList")",
                    dataType: "json",
