        // Add Legend in Map
        function legendAndInfo(e, mainAtt, attCode, layerId, layerName, isLegendColor, legendcolorField, layerTypeId) {

            mymap.removeLayer(legend);

            jQuery(".legend_info").empty();

            if (isLegendColor == 0) {
                legend.onAdd = function(map) {
                    for (var i = 0; i < e.features.length; i++) {
                        if (i == 0) {
                            legend_div.innerHTML += '<p class="legendTitle ' + layerId + '">' + layerName + '</p>';
                        }
                        legend_div.innerHTML += '<p class="' + layerId + '">' + e.features[i].properties[mainAtt] + '<i style="background:' + getRandomColor() + '"></i> </p>'; //{' + legendEndRange[i] + '}
                    }
                    return legend_div;
                };
            }
            else {

                legend.onAdd = function(map) {

                    jQuery.each(userDefinedColorList, function(index, val) {

                        for (var i = 0; i < userDefinedColorList[index].length; i++) {
                            if (i == 0) {
                                legend_div.innerHTML += '<p class="legendTitle ' + index + '">' + userDefinedColorList[index][i].get('legendName') + ' </p>';
                            }
                            if ((userDefinedColorList[index][i].get('iconPath') == "" || userDefinedColorList[index][i].get('iconSize') == 0) && userDefinedColorList[index][i].get('layerTypeId') == 4 || userDefinedColorList[index][i].get('layerTypeId') == 3) {
                                legend_div.innerHTML += '<p class="' + index + '">' + userDefinedColorList[index][i].get('name') + '<i style="background:' + userDefinedColorList[index][i].get('color') + '"></i> </p>';
                            }
                            else if (userDefinedColorList[index][i].get('iconSize') != 0 && userDefinedColorList[index][i].get('layerTypeId') == 2) {
                                legend_div.innerHTML += '<p class="' + index + '">' + userDefinedColorList[index][i].get('name') + '<i style="background:' + userDefinedColorList[index][i].get('color') + ';height:' + userDefinedColorList[index][i].get('iconSize') + 'px;text-align: center"></i> </p>';
                            }
                            else {
                                legend_div.innerHTML += '<div style="vertical-align: middle;"><p class="' + index + '"><img  src="../assets/images/' + userDefinedColorList[index][i].get('iconPath') + '" height="' + userDefinedColorList[index][i].get('iconSize') + '"/> ' + userDefinedColorList[index][i].get('name') + '</p></div>';
                            }
                        }
                    });

                    var draggable = new L.Draggable(legend_div);
                    draggable.enable()
                    return legend_div;
                };
            }

            legend.addTo(mymap);

        }

        //Get Random Color
        function getRandomColor() {
            var letters = '0123456789ABCDEF';

            var color = '#';
            for (var i = 0; i < 6; i++) {
                color += letters[Math.floor(Math.random() * 16)];
            }
            return color;
        }

        //Get User Defined Color
        function getColor(layerId, d) {
            for (var i = 0; i < userDefinedColorList[layerId].length; i++) {

                if (userDefinedColorList[layerId].length == 1) {
                    return userDefinedColorList[layerId][0].get('color');

                }

                if (d >= userDefinedColorList[layerId][i].get('value') && d < userDefinedColorList[layerId][i + 1].get('value')) {
                    return userDefinedColorList[layerId][i].get('color');
                }

                else if (d >= userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('value')) {
                    return userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('color');

                }
            }
        }

        function getIconSize(layerId, d) {
            for (var i = 0; i < userDefinedColorList[layerId].length; i++) {

                if (userDefinedColorList[layerId].length == 1) {
                    return userDefinedColorList[layerId][0].get('iconSize');

                }

                if (d >= userDefinedColorList[layerId][i].get('value') && d < userDefinedColorList[layerId][i + 1].get('value')) {
                    return userDefinedColorList[layerId][i].get('iconSize');
                }

                else if (d >= userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('value')) {
                    return userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('iconSize');

                }
            }
        }

        function getIconPath(layerId, d) {
            for (var i = 0; i < userDefinedColorList[layerId].length; i++) {

                if (userDefinedColorList[layerId].length == 1) {
                    return userDefinedColorList[layerId][0].get('iconPath');

                }

                if (d >= userDefinedColorList[layerId][i].get('value') && d < userDefinedColorList[layerId][i + 1].get('value')) {
                    return userDefinedColorList[layerId][i].get('iconPath');
                }

                else if (d >= userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('value')) {
                    return userDefinedColorList[layerId][userDefinedColorList[layerId].length - 1].get('iconPath');

                }
            }
        }


        //Set User Defined Color and Legend Name
        function getUserDefinedColor(layerUid, layerId, LegendName, layerTypeId, columnName) {
            userDefinedColorList[layerId] = {};
            var colorList = [];

            jQuery.ajax({
                type: "POST",
                url: "@Url.Action("GetUserDefinedLegendInfo")",
                dataType: "json",
                data: { layer_id: layerUid, columnName: columnName },
                before: jQuery("#busy-indicator").fadeIn(150),
                success: function(items) {

                    $.each(items,
                        function(i, item) {
                            colorList[i] = new Map([["legendName", LegendName], ["color", item.colorCode], ["value", item.attCode], ["name", item.attName], ["iconSize", item.iconSize], ["iconPath", item.iconPath], ["layerTypeId", layerTypeId]]);
                        });
                    userDefinedColorList[layerId] = colorList;

                },
                error: function(ex, status, error) {
                    //msg.init("error",
                    //    "Error... . . !",
                    //    "Failed to load Shape file. " + ex.responseText);

                    window.Swal.fire({
                        icon: "error",
                        title: "Failed to load Shape file. " + ex.responseText,
                        showConfirmButton: false, //true
                        timer: 3000   // remove timer
                    });
                }
                //complete: jQuery("#busy-indicator").fadeOut(150)
            });



        }



        function mapLabelShowHide(feature, layer, layerId, mainAtt, cLat, cLong) {


            var label = L.marker([layer.feature.properties[cLat], layer.feature.properties[cLong]], {
                icon: L.divIcon({
                    className: 'label mapLabel',
                    html: feature.properties[mainAtt],
                    iconSize: [100, 40],
                })
            });
            mapLabels.addLayer(label);

            if (jQuery("#map_label").prop("checked") == true) {
                mymap.addLayer(mapLabels);
                hideOverlappingTooltips();
            }
            else {
                if (mymap.hasLayer(mapLabels)) {
                    mymap.removeLayer(mapLabels);
                }
            }
        }



