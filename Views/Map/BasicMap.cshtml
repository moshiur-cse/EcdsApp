            max-width: 300px;
            resize: both;
        }

        .leaflet-popup-content{

            /*font-size: 1vw;*/
            font: 400 14px/1.0 Roboto, Helvetica, Arial, sans-serif;
            overflow: auto!important;
            /* min-height: 100px;*/
            max-height: 300px!important;
            max-width: 300px!important;
        }

            .legend_info i {
                /* width: 1.5vw;
                                                            height: 1.5vw;*/
