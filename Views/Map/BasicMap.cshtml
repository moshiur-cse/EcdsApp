                    var index = admin_div_list.indexOf(jQuery("#" + this.id).val());//get index
                    //remove div from the  array
                    admin_div_list.splice(index, 1);

                }


                jQuery.ajax({
                    type: "POST",
                    url: "@Url.Action("GetDistrictList")",
                    dataType: "json",
                    data: { divisionList: admin_div_list },
                    before: jQuery("#busy-indicator").fadeIn(150),
                    success: function(disticts) {

                        jQuery("#selectedDistrictList").empty();

                        //console.log(disticts);
                        var li_list = '';
                        jQuery.each(disticts, function(i, dist) {

                            //jQuery("#dist_" + dist.value).show();


                            li_list += '<li><a><input onclick="loadDistrict(' + dist.value + ')" type="checkbox" id="dist_' + dist.value + '" value="' + dist.value + '" class="DistrictList"><label for="dist_' + dist.value + '">' + dist.text + '</label></a></li>';

                        });
                        jQuery("#selectedDistrictList").append(li_list);

                    },
                    error: function(ex, status, error) {
                        msg.init("error",
                            "Error... . . !",
                            "Failed to load upazila list. " + ex.responseText);
                    },
                    complete: jQuery("#busy-indicator").fadeOut(150)
                });
                admin_code_list = admin_div_list;
                jQuery("#busy-indicator").fadeIn(150);
                LayerShowHide(g_layerUid, g_layerId, g_filepath, g_mainAttDisName, g_mainAtt, g_attCode, g_cLat, g_cLong, g_layerName, g_layerTypeId, g_isLegendColor, g_legendcolorField, admin_code_list, g_opacity, g_fillOpacity, g_weight, g_color, g_boundaryId, g_tableId);
                jQuery("#busy-indicator").fadeOut(150);
            }

        });

        function loadDistrict(id) {
            admin_code_list = [];
            admin_upz_list = [];
            jQuery("#selectedUpazilaList").empty();

            if (jQuery(this).closest('.DistrictList').prev().find('input[type=checkbox]').prop('checked', true)) {



                if (jQuery("#dist_" + id).prop("checked") == true) {
                    admin_dist_list.push(jQuery("#dist_" + id).val());

                } else {

                    var index = admin_dist_list.indexOf(jQuery("#dist_" + id).val());//get index
                    //remove div from the  array
                    admin_dist_list.splice(index, 1);

                }

                jQuery.ajax({
                    type: "POST",
                    url: "@Url.Action("GetUpazilaList")",
                    dataType: "json",
                    data: { upazilaList: admin_dist_list },
                    before: jQuery("#busy-indicator").fadeIn(150),
                    success: function(disticts) {

                        jQuery("#selectedUpazilaList").empty();

                        //console.log(disticts);
                        var li_list = '';
                        jQuery.each(disticts, function(i, dist) {

                            //jQuery("#dist_" + dist.value).show();


                            li_list += '<li><a><input onclick="loadUpazila(' + dist.value + ')" type="checkbox" id="upaz_' + dist.value + '" value="' + dist.value + '" class="UpazilaList"><label for="upaz_' + dist.value + '">' + dist.text + '</label></a></li>';

                        });
                        jQuery("#selectedUpazilaList").append(li_list);

                    },
                    error: function(ex, status, error) {
                        msg.init("error",
                            "Error... . . !",
                            "Failed to load upazila list. " + ex.responseText);
                    },
                    complete: jQuery("#busy-indicator").fadeOut(150)
                });

                admin_code_list = admin_dist_list;

                //console.log(admin_code_list);

                jQuery("#busy-indicator").fadeIn(150);
                LayerShowHide(g_layerUid, g_layerId, g_filepath, g_mainAttDisName, g_mainAtt, g_attCode, g_cLat, g_cLong, g_layerName, g_layerTypeId, g_isLegendColor, g_legendcolorField, admin_code_list, g_opacity, g_fillOpacity, g_weight, g_color, g_boundaryId, g_tableId);
                jQuery("#busy-indicator").fadeOut(150);
            }
        }



        function loadUpazila(id) {
            admin_code_list = [];

            if (jQuery(this).closest('.UpazilaList').prev().find('input[type=checkbox]').prop('checked', true)) {
                admin_code_list = []
                if (jQuery("#upaz_" + id).prop("checked") == true) {
                    admin_upz_list.push(jQuery("#upaz_" + id).val());

                } else {
                    var index = admin_upz_list.indexOf(jQuery("#upaz_" + id).val());//get index
                    admin_upz_list.splice(index, 1);
                }
                admin_code_list = admin_upz_list;
                jQuery("#busy-indicator").fadeIn(150);
                LayerShowHide(g_layerUid, g_layerId, g_filepath, g_mainAttDisName, g_mainAtt, g_attCode, g_cLat, g_cLong, g_layerName, g_layerTypeId, g_isLegendColor, g_legendcolorField, admin_code_list, g_opacity, g_fillOpacity, g_weight, g_color, g_boundaryId, g_tableId);
                jQuery("#busy-indicator").fadeOut(150);
            }
        }


        function DisplayDetailsInfoes(adminCodeForGetResult, name) {

            //alert(+adminCodeForGetResult+" "+name);
            //return;

            $("#modalWithDetailsInfo .modal-body").empty();
