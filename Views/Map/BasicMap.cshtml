                        //fillColor: isLegendColor == 0 ? '#ffffff00' : userDefinedColorList[feature.properties[legendcolorField]], //colorList[feature.properties[attCode]],
                        //fillColor: isLegendColor == 0 ? '#ffffff00' : userDefinedColorList[layerId][mapBindData[layerId][feature.properties[attCode]]],
                        //fillColor: isLegendColor == 0 ? '#ffffff00' : getColor(layerId, mapBindData[layerId][feature.properties[attCode]]),
                        fillColor: isLegendColor == 0 ? '#ffffff00' : tDataColor,
                        weight: weight,
                        opacity: opacity,
                        color: tDataColor,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }

                else if (isLegendColor == 1 && layerTypeId == 3) {

                    var uColor = getColor(layerId, feature.properties[legendcolorField]);
                    return {
                        fillColor: uColor,
                        weight: weight,
                        opacity: opacity,
                        color: uColor,
                        /* dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
                else if (isLegendColor == 1 && layerTypeId == 2) {

                    var uColor = getColor(layerId, feature.properties[legendcolorField]);

                    if (layerId == "rail_line") {
                        return {
                            color: uColor,
                            weight: getIconSize(layerId, feature.properties[legendcolorField]) != 0 ? getIconSize(layerId, feature.properties[legendcolorField]) : weight,
                            opacity: opacity,
                            dashArray: '4,4',
                            lineJoin: 'round',  //miter | round | bevel
                        };
                    } else {
                        return {
                            color: uColor,
                            weight: getIconSize(layerId, feature.properties[legendcolorField]) != 0 ? getIconSize(layerId, feature.properties[legendcolorField]) : weight,
                            opacity: opacity,
                        };

                    }


                }
                else if (isLegendColor == 0 && layerTypeId == 3) {
                    //alert(color);
                    return {
                        fillColor: '#ffffff00',
                        weight: weight,
                        opacity: opacity,
                        /* transparent: true,*/
                        color: color,
                        /*dashArray: '1',*/
                        fillOpacity: fillOpacity
                    };
                }
                else {
                    return {
                        fillColor: '#ffffff00',
                        weight: 0.0,
                        opacity: 0.0,
                        /* transparent: true,*/
                        color: '#ffffff00',
                        /*dashArray: '1',*/
                        fillOpacity: 0.0
                    };

                }
            }
