        jQuery('#map_layer_data').click(function ($) {



            if (typeof layerData === "undefined") {
                window.Swal.fire({
                icon: "error",
                title: "Failed to load data: Please add a layer ",
                showConfirmButton: false, //true
                timer: 3000   // remove timer
                });
                return false;          
            }


            jQuery('#AttributeDiv').empty();
            var tableContent = '<div> <button class="btn btn-success"  onclick="showBundleAndMetaData(\'' + g_layerUid +'\')">View Metadata</button><hr/></div><table class="table table-centered table-nowrap mb-0">';
            for (var i = 0; i < layerData.features.length; i++) {

                if (i == 0) {
                    tableContent += '<tr>';
                    for (var j = 0; j < Object.getOwnPropertyNames(layerData.features[i].properties).length; j++) {
                        tableContent += '<th>' + Object.getOwnPropertyNames(layerData.features[i].properties)[j] + '</th>';
                    }
                    tableContent += '</tr>';
                }
                tableContent += '<tr>';
                for (var j = 0; j < Object.getOwnPropertyNames(layerData.features[i].properties).length; j++) {
                    tableContent += '<td>' + layerData.features[i].properties[Object.getOwnPropertyNames(layerData.features[i].properties)[j]] + '</td>';
                }
                tableContent += '</tr>';
            }
            tableContent += '</table>';
            jQuery('#AttributeDiv').append(tableContent);


            /*Object.getOwnPropertyNames(layerData.features[0].properties)*/

            if (jQuery('#AttributeDiv').is(':visible')) {
                jQuery('#AttributeDiv').slideUp();

            } else {
                jQuery('#AttributeDiv').slideDown();
            }
        });


        $("#AttributeDiv").draggable();

        function showBundleAndMetaData(layerId) {

            //alert(layerId);
            $("#modalWithDetailsInfo .modal-body").empty();
             $.ajax({
                    type: "GET",
                    url: '@Url.Action("GetMetadata", "Map")',
                    dataType: "html",
                    data: { layerId: layerId  },
                    before: $("#busy-indicator").fadeIn(150),
                }).done(function (compInfo) {
                    
                    $("#modalWithDetailsInfo .modal-body").append(compInfo);
                    $('#modalWithDetailsInfo').modal('show');

                    //$("#exampleModalScrollable").init
                }).fail(function (ex) {
                    window.Swal.fire({
                        icon: "error",
                        title: "Failed to load meta-data. " + ex.responseText,
                        showConfirmButton: false, //true
                        timer: 3000   // remove timer
                    });
                }).always(function () {
                    $("#busy-indicator").fadeOut(150);
                });
            return false;
        }
