        function setTopLayer(layerName) {

            //console.log(name);
            //console.log(data_layer_details[layerName].get('layerUid'));

            g_layerId = layerName;
            jQuery("#busy-indicator").fadeIn(150);
            LayerShowHide(data_layer_details[layerName].get('layerUid'), data_layer_details[layerName].get('layerId'), data_layer_details[layerName].get('filepath'), data_layer_details[layerName].get('mainAttDisName'), data_layer_details[layerName].get('mainAtt'), data_layer_details[layerName].get('attCode'), data_layer_details[layerName].get('cLat'), data_layer_details[layerName].get('cLong'), data_layer_details[layerName].get('layerName'), data_layer_details[layerName].get('layerTypeId'), data_layer_details[layerName].get('isLegendColor'), data_layer_details[layerName].get('legendcolorField'), admin_code_list, data_layer_details[layerName].get('opacity'), data_layer_details[layerName].get('fillOpacity'), data_layer_details[layerName].get('weight'), data_layer_details[layerName].get('color'), data_layer_details[layerName].get('boundaryId'), data_layer_details[layerName].get('tableId'));
            jQuery("#busy-indicator").fadeOut(150);

        }

        jQuery('#map_layer_data').click(function($) {



            if (typeof layerData === "undefined") {
                window.Swal.fire({
                    icon: "error",
                    title: "Failed to load data: Please add a layer ",
                    showConfirmButton: false, //true
                    timer: 3000   // remove timer
                });
                return false;
            } else {


                jQuery('#AttributeDiv').empty();


                var tableContent = '<div> <button class="btn btn-success"  onclick="showBundleAndMetaData(\'' + g_layerUid + '\')">View Metadata</button><hr/></div><table class="table table-centered table-nowrap mb-0">';


                for (var i = 0; i < layerData.features.length; i++) {

                    if (i == 0) {
                        tableContent += '<tr>';
                        for (var j = 0; j < Object.getOwnPropertyNames(layerData.features[i].properties).length; j++) {

                            if (Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "CntLat" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "CntLong" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "LegendId" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "GeoCode" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "Geocode") {
                                continue;
                            }
                            tableContent += '<th>' + Object.getOwnPropertyNames(layerData.features[i].properties)[j] + '</th>';
                        }
                        if (g_layerTypeId == 4) {
                            tableContent += '<th>Value</th>';
                        }
                        tableContent += '</tr>';
                    }
                    tableContent += '<tr>';
                    for (var j = 0; j < Object.getOwnPropertyNames(layerData.features[i].properties).length; j++) {

                        if (Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "CntLat" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "CntLong" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "LegendId" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "GeoCode" || Object.getOwnPropertyNames(layerData.features[i].properties)[j] == "Geocode") {
                            continue;
                        }
                        tableContent += '<td>' + layerData.features[i].properties[Object.getOwnPropertyNames(layerData.features[i].properties)[j]] + '</td>';

                    }
                    if (g_layerTypeId == 4) {
                        tableContent += '<td>' + mapBindData[g_layerId][layerData.features[i].properties[g_attCode]].get('value') + '</td>';
                    }
                    tableContent += '</tr>';
                }



                tableContent += '</table>';
                jQuery('#AttributeDiv').append(tableContent);
            }


            /*Object.getOwnPropertyNames(layerData.features[0].properties)*/

            if (jQuery('#AttributeDiv').is(':visible')) {
                jQuery('#AttributeDiv').slideUp();

            } else {
                jQuery('#AttributeDiv').slideDown();
            }
        });

        jQuery('#map_legend').click(function($) {
            if (jQuery('.legend_info').is(':visible')) {
                jQuery('.legend_info').slideUp();
