            if (mymap.hasLayer(data_layer[layerId])) {
                mymap.removeLayer(data_layer[layerId]);
                mymap.removeLayer(legend);
                $("p." + layerId).remove();
                $("#map_layer_" + layerId).remove();
                //colorList = {};
                mymap.removeLayer(mapLabels);
                mapLabels = L.layerGroup();
            }


            data_layer[layerId] = L.geoJson(null, {
                style: style,
                onEachFeature: onEachFeature,
                pointToLayer: pointToLayer,

            });

            $.getJSON(layerPath, function(LayerInfo) {
                if (!LayerInfo) return;

                data_layer[layerId].addData(LayerInfo);
                layerData = LayerInfo;
                /*console.log(layerData);*/

