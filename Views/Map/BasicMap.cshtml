            function highlightFeature(e) {
                var layer = e.target;
                //var popupContent = '<div style="width:250px;text-align:center;">' +mainAttDisName+" : " + layer.feature.properties[mainAtt] + '</div>';
                var popupContent = '<div style="width:300px;text-align:center;"><p>' + mainAttDisName + " : " + layer.feature.properties[mainAtt] + '</p>' + ((firstAtt != null) ? '<p>' + (firstAttDisName + " : " + layer.feature.properties[firstAtt]) + '</p>' : " ") + '</div>';
                layer.setStyle({
                    //weight: 2,
                    //color: '#E11F21',
                    dashArray: '',
                    fillOpacity: 0.4
                }).bindPopup(popupContent).openPopup(e.latlng);
                if (!L.Browser.ie && !L.Browser.opera && !L.Browser.edge) {
                    layer.bringToFront();
                }
            }
            function resetHighlight(e) {
                mymap.closePopup();
                //data_layer[layerId].resetStyle(e.target);
            }

