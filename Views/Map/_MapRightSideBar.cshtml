@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using EcdsApp.Models.ViewModels.Map
@using EcdsApp.Models
<!-- Right Sidebar -->

<div class="right-bar">

    <div data-simplebar class="h-100">

        <div class="rightbar-title d-flex align-items-center px-3 py-4 bg-success">

            <h5 class="m-0 me-2" style="color: white">Filter Options</h5>

            <a href="javascript:void(0);" class="right-bar-toggle ms-auto">
                <i class="mdi mdi-close noti-icon"></i>
            </a>
        </div>
        <hr class="mt-0" />

        <div class="p-3">
            <h5 class="text-center">Map Layers</h5>
            <div id="sidebar-menu">
                @*Left Menu Start*@
                @*<ul  class="metismenu list-unstyled map_layer_list">
                    <li style="text-align:center">No Layer Added</li>
                    </ul>*@
                <div class="map_layer_list">
                    <p style="text-align:center">No Layer Added</p>
                </div>
            </div>



            <div>
                <label for="customRange3" class="form-label">Transparency</label><br />
                @*0%*@
                <input oninput="ChangeOpacity(this.value)" type="range" class="form-range" min="0.0" max="1.0" step="0.1" value="0.6">
                @*100%*@
            </div>




            <div class="row">
                <h5 style="margin-left:5px" class="control-group mb-3 mt-3">Map Filtering</h5>

                <div class="col-md-4">
                    <div class="form-check ">
                        <input type="radio" id="radioDivision" name="radio" class="form-check-input radioButton" value="Division" checked="checked"><label class="form-check-label" for="radioDivision">Division</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="radio" id="radioDistrict" name="radio" class="form-check-input radioButton" value="District"><label class="form-check-label" for="radioDistrict">District</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input type="radio" id="radioUpazila" name="radio" class="form-check-input radioButton" value="Upazila"><label class="form-check-label" for="radioUpazila">Upazila</label>
                    </div>
                </div>
            </div>
            <br />
            <div class="row">





                <div class="accordion mb-1" id="DivisionList">
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDivision" aria-expanded="true" aria-controls="collapseDivision">
                                Select Division
                            </button>
                        </h2>
                        <div id="collapseDivision" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#DivisionList">
                            <div class="accordion-body">
                                <ul class="metismenu list-unstyled">
                                    @foreach (AdminBoundaryDivision item in ViewBag.DivList)
                                    {

                                        <li>
                                            <a><input type="checkbox" id="div_@item.DivisionGeoCode" value="@item.DivisionGeoCode" class="DivisionList"><label for="div_@item.DivisionGeoCode">@item.DivisionName</label></a>
                                        </li>

                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>




                <div class="accordion" id="DistrictList" style="display:none">
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseTwo" aria-expanded="true"
                                    aria-controls="collapseTwo">
                                Select District
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse"
                             aria-labelledby="headingOne" data-bs-parent="#DistrictList">
                            <div class="accordion-body">
                                <ul class="metismenu list-unstyled" id="selectedDistrictList">
                                   @* @foreach (AdminBoundaryDistrict item in ViewBag.DistList)
                                    {
                                        <li>
                                            <a><input type="checkbox" id="dist_@item.DistrictGeoCode" value="@item.DistrictGeoCode" class="DistrictList"><label for="dist_@item.DistrictGeoCode">@item.DistrictName</label></a>
                                        </li>

                                    }*@
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="accordion" id="UpazilaList" style="display:none">
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="headingUpazila">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#collapseUpazila" aria-expanded="true"
                                    aria-controls="collapseUpazila">
                                Select Upazila
                            </button>
                        </h2>
                        <div id="collapseUpazila" class="accordion-collapse collapse"
                             aria-labelledby="headingOne" data-bs-parent="#UpazilaList">
                            <div class="accordion-body">
                                <ul class="metismenu list-unstyled" id="selectedUpazilaList">
                                   @* @foreach (AdminBoundaryUpazila item in ViewBag.UpazList)
                                    {
                                        <li>
                                            <a><input type="checkbox" id="upaz_@item.UpazilaGeoCode" value="@item.UpazilaGeoCode" class="UpazilaList"><label for="upaz_@item.UpazilaGeoCode">@item.UpazilaName</label></a>
                                        </li>

                                    }*@
                                </ul>
                            </div>
                        </div>


                    </div>
                </div>

            </div>

        </div> <!-- end slimscroll-menu-->
    </div>
</div>

