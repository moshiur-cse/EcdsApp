
@{
    ViewData["Title"] = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href='https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css' rel='stylesheet'>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
<style>
@@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Montserrat:wght@300&display=swap');
.cont-panel{
    position: relative;
    padding: 0;
    width: 100vw;
    height: 80vh;
    background-color: white;
}

.cont-second{
    position: relative;
    bottom:0;
    height: 40vh;
    background-color: #d4d4d4;
}

.cont-card{
    border-radius: 20px;
    position: absolute;
    background-color: white;
    z-index: 10;
    top:40vh;
    width:60vw;
    height: 50vh;
    box-shadow: rgba(50, 50, 93, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px;
}
.iframe{
    border-radius: 20px 0 0 20px;
    width: 100%;
    height: 50vh;
}

.cont-rpan{
    background-color: #2c4b7a;
    border-radius: 0 20px 20px 0;
    width: 100%;
    height: 50vh;
    color:white;

}

.fnt-title{
    font-family: 'Playfair Display', serif;
    font-size: 2.00rem;
}

.fnt-body{
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
}

.mb-20{
    margin-bottom:20px;
}

.mb-50{
    margin-bottom:50px;
}
</style>
<div class="page-content">   
        
        <div class="row">
            <div class="cont-panel">
                <div class="cont-second"></div>
            </div>
        </div>
        <div class="d-flex justify-content-center align-items-center">
            <div class="cont-card">
                <div class="row">
                    <div class="col-12 col-lg-7">
                        <iframe
                            class="iframe"
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3651.0800451526084!2d90.3738161147847!3d23.780163784574743!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3755c74ca1b4db15%3A0x6f9e2884a033e2ac!2sBangladesh%20Bureau%20of%20Statistics!5e0!3m2!1sen!2sbd!4v1647921988108!5m2!1sen!2sbd" 
                            width="600" 
                            height="450" 
                            style="border:0;" 
                            allowfullscreen="" 
                            loading="lazy">
                        </iframe>
                    </div>
                    <div class="col-12 col-lg-5 cont-rpan d-flex jusity-content center fnt-body">
                        <div>
                            <h3 class="text-center pb-2 fnt-title mb-50">Contact</h3>
                            <h6><i class="bx bx-mail-send pr-2 mb-20"></i>dg@bbs.gov.bd</h6>
                            <h6><i class="bx bx-phone-call pr-1 mb-20"></i> +88-02-9112589</h6>
                            <h6><i class="bx bx-map pr-2"></i>Parishankhyan Bhaban, E-27/A, Agargaon. Sher-e-Bangla Nagar, Dhaka-1207, Bangladesh</h6>
                        </div>                        
                    </div>
                </div>
            </div>
        </div>
       
</div>

