        $(function () {
            function groupTable($rows, startIndex, total) {
                if (total === 0) {
                    return;
                }
                var i, currentIndex = startIndex, count = 1, lst = [];
                var tds = $rows.find('td:eq(' + currentIndex + ')');
                var ctrl = $(tds[0]);
                lst.push($rows[0]);
                for (i = 1; i <= tds.length; i++) {
                    if (ctrl.text() === $(tds[i]).text()) {
                        count++;
                        $(tds[i]).addClass('deleted');
                        lst.push($rows[i]);
                    } else {
                        if (count > 1) {
                            ctrl.attr('rowspan', count);
                            groupTable($(lst), startIndex + 1, total - 1);
                        }
                        count = 1;
                        lst = [];
                        ctrl = $(tds[i]);
                        lst.push($rows[i]);
                    }
                }
            }

            groupTable($('#tblLayerData tr:has(td)'), 0, 2);
            $('#tblLayerData .deleted').remove();
        });

        var options = {
            chart: { height: 339, type: "line", stacked: !1, toolbar: { show: !1 } },
            stroke: { width: [0, 2, 4], curve: "smooth" },
            plotOptions: { bar: { columnWidth: "30%" } },
            colors: ["#5b73e8", "#dfe2e6", "#f1b44c"],
            series: [{ name: "Flood", type: "column", data: @Html.Raw(yFloodValue) },
                { name: "Land Slide", type: "area", data: @Html.Raw(yLandSlideValue) },
                { name: "Drought", type: "line", data: @Html.Raw(yDroughtValue) }],
                //{ name: "Drought", type: "line", data: [5, 11, 21, 2, 14, 6, 18, 25, 15, 10, 9, 10] }],
            fill: {
                opacity: [.85, .25, 1],
                gradient: { inverseColors: !1, shade: "light", type: "vertical", opacityFrom: .85, opacityTo: .55, stops: [0, 100, 100, 100] }
            },
            labels: @Html.Raw(xLabels),
            markers: { size: 0 },
            xaxis: { title: { text: "Upazila" } },
            yaxis: { title: { text: "Value" } },
            tooltip: {
                shared: !0, intersect: !1,
                y: { formatter: function (e) { return void 0 !== e ? e.toFixed(0) + " value" : e } }
            },
            grid: { borderColor: "#f1f1f1" }
        };

        (chart = new ApexCharts(document.querySelector("#sales-analytics-chart"), options)).render();
</script>
