@model EcdsApp.Models.ViewModels.Dashboard.DashboardVm
@using Newtonsoft.Json

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var mapData = JsonConvert.SerializeObject(Model.DistrictWisePoverties);
    var legendData = JsonConvert.SerializeObject(Model.LayerLegendColors);
    var chartData = JsonConvert.SerializeObject(Model.ChartDataVms);

    var xLabels = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.District.DistrictName));
    var yMale = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.Male));
    var yFemale = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.Female));

    //var yUrban = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.Urban));
    //var yRural = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.Rural));
    //var yOther = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.Other));

    var yTotal = JsonConvert.SerializeObject(Model.DistrictWisePopulations.Select(x => x.Total));
}

