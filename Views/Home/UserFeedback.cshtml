
@{
    ViewData["Title"] = "UserFeedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href='https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css' rel='stylesheet'>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css">
<style>
@@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');

::placeholder {
    color: grey;
    font-weight: 500;
}

.cont-main{
    width: 100vw;
    height: 100vh;
    background-image: url(./Snow.svg);
    z-index:-1;
}
.feed-card{
    border-radius: 15px;
    padding: 0 20px;
    box-shadow: rgba(0, 0, 0, 0.25) 0px 25px 50px -12px;
    background: whitesmoke;
}

.fnt-title{
    font-family: 'Playfair Display', serif;
    font-size: 1.75rem;
}

.fnt-body{
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
}

.form-input{
    width: 100%;
    border-radius: 15px;
    box-shadow: rgba(50, 50, 93, 0.25) 0px 13px 27px -5px, rgba(0, 0, 0, 0.3) 0px 8px 16px -8px;       
    border:none;
    padding:10px;
}

.mb-20{
    margin-bottom:20px;
}

.mb-50{
    margin-bottom:50px;
}

.btn-submit{
    background-color: blueviolet;
    padding:8px 50px;
    
}

.btn-submit:hover{
    background-color: white;
    color:blueviolet;
    font-weight: 700;
    transition: background-color .5s ease-in;
}

.msg-panel>h6{
    padding:10px 5px;
    font-size: 1.15rem;
    text-align: justify;
    color:#393554;
}

.bx{
    font-size: 1.85rem;
    color:red;
}
.white-cont{
    background:white;
}
</style>

<div class="page-content">
    <div class="white-cont">
        <div class="row cont-main justify-content-around align-items-center">
            <div class="feed-card col-11 col-md-5 col-lg-6 col-xl-4 mb-5 mb-sm-0">
                <div class="msg-panel">
                    <div class="d-flex justify-content-center py-2">
                        <i class='bx bx-info-circle'></i>
                    </div>
                    <h6>If you have any message/query/feedback, you can submit that to ECDS Technical Team by using right message form. Our team would try to respond as soon as possible.</h6>
                </div>
            </div>
            <div class="feed-card col-11 col-md-7 col-lg-6 col-xl-4">
                <h3 class="fnt-title mb-50 text-center py-2">Message Us</h3>
                <div class="form-group">
                   <input type="email" class="form-input" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Name">
                </div>
                <div class="form-group">
                    <input type="email" class="form-input" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Email">
                 </div>
                <div class="form-group">
                    <textarea class="form-input" cols="30" rows="10" placeholder="Message"></textarea>
                </div>
                <div class="form-group my-4 d-flex justify-content-center">
                    <button class="btn btn-primary btn-submit">Send</button>
                </div>
            </div>
        </div>        
    </div>
</div>


