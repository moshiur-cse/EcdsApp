
@{
    ViewBag.Title = "Confirm Email";
    Layout = "_Layout";
}

<style>
    
    .btn-outline-info {
        background-color: rgba(10,23,37,1) !important;
        color: white;
    }

    .btn-outline-info:hover {
        color: red !important;
        background-color: whitesmoke !important;
        transition: 0.8s ease;
    }
</style>

<div style="margin-top:100px;" class="container">
    <div style="height:70vh;" class="container d-flex justify-content-center align-items-center">
        @if (ViewBag.Message == "Success")
        {
            <div class="alert alert-success col-4" role="alert">
                <h4 class="alert-heading text-center">Congratulation !</h4>
                <hr />
                <p class="text-center">You have successfully verified your email. Now you can login into ECDS platform by using existing credentials. Thank you.</p>
                <hr>
                <div class="d-flex justify-content-center">
                    <a class="btn btn-info px-4" asp-area="Identity" asp-page="/Account/Login">Login</a>
                </div>
                
            </div>
        }

        else
        {
            <div class="alert alert-danger col-4" role="alert">
                <h4 class="alert-heading">Failed !</h4>
                <hr />
                <p>Failed to confirm the email</p>
                <hr>                
            </div>

        }

    </div>
</div>
