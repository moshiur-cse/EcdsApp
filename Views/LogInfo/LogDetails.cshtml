@model IEnumerable<EcdsApp.Models.HitCountAndLogModels.DownloadLog>

@{
    ViewData["Title"] = "Log Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int count = 1;
}
<div class="page-content my-5 bg-white">
    <div class="container-fluid min-vh-75">
        <div class="row">
            <h4 class="text-center my-4">Log of Downloaded Data</h4>
            <div class="table-responsive mb-4">
                <table id="logtable" class="table table-striped table-bordered">
                    <thead>
                    <tr>
                        <th scope="col">Serial No.</th>
                        <th scope="col">Downloaded Data</th>
                        <th scope="col">IP Address</th>
                        <th scope="col">Downloaded At</th>
                        <th scope="col">Username</th>
                        <th scope="col">Email</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@count</td>
                            <td>@item.ThemeLayerDetail.LayerDisplayName</td>
                            <td>@item.IPAddress</td>
                            <td>@item.GeneratedAt</td>
                            <td>@item.User.UserName</td>
                            <td>@item.User.Email</td>
                        </tr>
                        count++;
                    }

                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

@section Scripts
{
    <script>
    $('#logtable').dataTable( {
          "searching": true
        } );
    </script>
    
}
