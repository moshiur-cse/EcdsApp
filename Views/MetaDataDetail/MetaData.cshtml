@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model EcdsApp.Models.ThemeModels.MetaDataDetail



@{
    ViewData["Title"] = "Details Data";
    var isShowLayout = (ViewBag.IsShowLayout != null && ViewBag.IsShowLayout == 1);
    var isShowAction = (ViewBag.IsShowAction != null && ViewBag.IsShowAction == 1);

    Layout = isShowLayout ? "~/Views/Shared/_Layout.cshtml" : null;
}






<table id="datatable-buttons" class="table table-striped table-bordered th-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
    <thead>
        <tr>
            <th class="col-sm-2">
                Theme Name
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.ThemeLayerDetails.SubThemes.Themes.ThemeName)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                Sub-Theme Name
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.ThemeLayerDetails.SubThemes.SubThemeName)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                Layer Name
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.ThemeLayerDetails.LayerDisplayName)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.Title)
            </td>
        </tr>
        <tr>

            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.Abstract)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.Abstract)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.General)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.General)
            </td>
        </tr>
        <tr>

            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.Quality)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.Quality)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.Completeness)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.Completeness)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.HistoryOfTheDataSet)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.HistoryOfTheDataSet)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.PurposeOfProduction)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.PurposeOfProduction)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.ProcessDescription)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.ProcessDescription)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.TypeOfDataSet)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.TypeOfDataSet)
            </td>
        </tr>
        <tr>

            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.DataSetLanguage)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.DataSetLanguage)
            </td>
        </tr>
        <tr>
            <th class="col-sm-2">
                @Html.DisplayNameFor(model => model.AdditionalInfoSourceForDataSet)
            </th>
            <td class="col-sm-10">
                @Html.DisplayFor(model => model.AdditionalInfoSourceForDataSet)
            </td>

        </tr>
<thead>
</table>


