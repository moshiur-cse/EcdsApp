@model IEnumerable<EcdsApp.Models.Message>
@{
	ViewData["Title"] = "All Messages";
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="page-content">
	<div class="container-fluid">
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-body">
						<div class="d-flex justify-content-center align-items-center">
							<h4 class="display-6 mb-0 fs-4">List of Messages</h4>							
						</div>						
					</div>
				</div>
				<div class="card">
					<div class="card-body">
						<div class="table-responsive mt-2">
							<!--Special Buttons-->
							@*<div class="col-12 d-flex justify-content-center justify-content-md-end align-items-center my-3">

								<!--First Dropdown-->
								<div class="dropdown me-3">
									<button class="btn btn-danger dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
										No. of Rows <i class="bx bxs-down-arrow pt-1"></i>
									</button>
									<ul class="dropdown-menu">
										<li class="my-2">
											<span onclick="LoadData(10)">Load 10 rows</span>
										</li>
										<li class="my-2">
											<span onclick="LoadData(25)">Load 25 rows</span>
										</li>
										<li class="my-2">
											<span onclick="LoadData(50)">Load 50 rows</span>
										</li>
										@* <li class="my-2">
											<span onclick="LoadFullData()">All rows</span>
											</li>*@
											@*
									</ul>
								</div>
								<!--End First Dropdown-->
								<!--Second Dropdown-->
								<div class="dropdown">
									<button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
										Export Columns <i class="bx bxs-down-arrow pt-1"></i>
									</button>
									<ul class="dropdown-menu">
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Division Geo Code
												</label>
											</div>
										</li>
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Division Name
												</label>
											</div>
										</li>
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Division Name Bangla
												</label>
											</div>
										</li>
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Sorting Order
												</label>
											</div>
										</li>
									</ul>
								</div>
								<!--End Second Dropdown-->
							</div>*@

							<!--Special Buttons End-->
							<table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
								<thead>
									 <tr>
                                        <th>Action</th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.FullName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.Email)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.Msg)
                                        </th>
										 <th>
                                            @Html.DisplayNameFor(model => model.Status.MessageStatus)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.CreatedAt)
                                        </th>
                                    </tr>
								</thead>
								<tbody>
									@foreach (var item in Model)
									{
										<tr>
                                            <td>
                                                <a href=""><i role="button" class="text-primary far fa-eye font-size-20 edit-btn"></i></a>                                                
                                            </td>
                                            <td data-field="id">
                                                @Html.DisplayFor(modelItem => item.FullName)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Email)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Msg)
                                            </td>
											<td>
                                                @Html.DisplayFor(modelItem => item.Status.MessageStatus)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.CreatedAt)
                                            </td>
                                        </tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts{
	<script type="text/javascript">
	let tableProps={
		//dom: 'Bfrtip',
		processing: true,
		filter:true,
		paging:true,
		fixedHeader: true,
		scrollY:true,
	}
	let table=$("#datatable-buttons").DataTable(tableProps)
	</script>
}