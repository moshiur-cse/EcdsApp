@model IEnumerable<EcdsApp.Models.ThemeModels.LayerLegendColor>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ThemeLayerDetails)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LayerMainAttribureValue)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LayerLegendColorCode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LayerLegendDisplayName)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ThemeLayerDetails.LayerFileName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LayerMainAttribureValue)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LayerLegendColorCode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LayerLegendDisplayName)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.LayerLegendColorId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.LayerLegendColorId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.LayerLegendColorId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
