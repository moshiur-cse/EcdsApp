@model IEnumerable<EcdsApp.Models.RegionModels.AdminBoundaryUnion>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .tab-card{
        max-height:50vh;
        overflow:auto;
    }
</style>


<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h3 class="display-6 mb-0">List of Union</h3>
                        <p class="card-title-desc">Union Details Information</p>
                        <a asp-action="Create" class="btn btn-info btn-rounded waves-effect waves-light w-lg">Add New Union</a>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive mt-2 tab-card">
                            
                            <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
                                <thead>
                                    <tr>
                                        <th>Action</th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.Upazila.UpazilaName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UnionName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UnionNameBangla)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.MunicipalityName)
                                        </th>
                                         <th>
                                            @Html.DisplayNameFor(model => model.MunicipalityGeoCode)
                                        </th>                                         
                                        <th>
                                            @Html.DisplayNameFor(model => model.SortingOrder)
                                        </th>
                                        
                                    </tr>
                                </thead>
                                <tbody class="maxvh-50 overflow-auto">
                                   
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @*<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModal">
  Launch demo modal
</button>*@
</div>


<!--Bootstrap Modal-->
<div class="modal fade" id="myModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
   <div class="modal-dialog">
      <div class="modal-content">
         <div class="modal-header">
            <h5 class="modal-title" id="exampleModalLabel">Edit Union Info</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
         </div>
         <div class="modal-body">
             <div id="alert"></div>
            <form>
               <div class="mb-3">
                  <label class="form-label" for="inputEmail">Upazila</label>
                  <input type="email" name="upazilaName" class="form-control" id="upazilaName">
               </div>
               <div class="mb-3">
                  <label class="form-label" for="inputEmail">Union Name</label>
                  <input type="email" name="unionName" class="form-control" id="unionName">
               </div>
               <div class="mb-3">
                  <label class="form-label" for="inputEmail">Union Name Bangla</label>
                  <input type="email" name="unionNameBangla" class="form-control" id="unionNameBangla">
               </div>
               <div class="mb-3">
                  <label class="form-label" for="inputEmail">Municipality Name</label>
                  <input type="email" name="municipalityName" class="form-control" id="municipalityName">
               </div>
               <div class="mb-3">
                  <label class="form-label" for="inputEmail">Municipality GEO Code</label>
                  <input type="email" name="municipalityGeoCode" class="form-control" id="municipalityGeoCode">
               </div>
               <div class="mb-3">
                  <label class="form-label" for="inputEmail">Sorting Order</label>
                  <input type="email" name="sortingOrder" class="form-control" id="sortingOrder">
               </div>
               <input type="hidden" name="unionGeoCode" class="form-control" id="unionGeoCode">
               <input type="hidden" name="unionGeoCode" class="form-control" id="upazilaGeoCode">
            </form>
         </div>
         <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" id="submit" class="btn btn-primary">Save changes</button>
         </div>
      </div>
   </div>
</div>
<!--End Bootstrap Modal-->


