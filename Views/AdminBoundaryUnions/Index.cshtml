//====Update Information in the database
const UpdateInDb =()=>{
    
    //===get values from input fields and add them to arrays
    //let elements=['unionName','unionNameBangla','municipalityName','municipalityGeoCode','sortingOrder','unionGeoCode']
    let geoCodes=[arry[arry.length-2],arry[arry.length-1]]
    arry=[]
    for(let i=0;i<=5;i++){
        arry.push($("#d"+i).val())
    }

    $.post(
        '@Url.Action("Edit")',
        {
            
            'adminBoundaryUnion.unionGeoCode':geoCodes[0],
            'adminBoundaryUnion.upazilaGeoCode':geoCodes[1],
            'adminBoundaryUnion.upazilaName':arry[0],
            'adminBoundaryUnion.unionName':arry[1],
            'adminBoundaryUnion.unionNameBangla':arry[2],
            'adminBoundaryUnion.municipalityName':arry[3],
            'adminBoundaryUnion.municipalityGeoCode':arry[4],
            'adminBoundaryUnion.sortingOrder':arry[5]
        },
        function(data){
           //===successfully saved now
           if(data=="success"){

           }            
        }
     );
}

//====custom input field insert
$(document).on("click", '.edit-btn', function(){
    console.log("s")
    const td=$(this).parent()
    const allDataInRow=td.parent().children()
    for(let i=1;i<allDataInRow.length;i++){
       arry.push(allDataInRow[i].innerText)
    }        
    arry.push($(this).attr("d-ungcode"))
    arry.push($(this).attr("d-upgcode"))
    
    //console.log($(this).attr("d-ungcode"))
    $(td).parent().html(`
    <td class="sorting_1 dtr-control"><button class="save-btn">Save</button></td>
    <td><input type="text" id="d0" class="form-control" value="${arry[0]}"/></td>
    <td><input type="text" id="d1" class="form-control" value="${arry[1]}"/></td>
    <td><input type="text" id="d2" class="form-control" value="${arry[2]}"/></td>
    <td><input type="text" id="d3" class="form-control" value="${arry[3]}"/></td>
    <td><input type="text" id="d4" class="form-control" value="${arry[4]}"/></td>
    <td><input type="text" id="d5" class="form-control" value="${arry[5]}"/></td>`)
})

//==== save button

$(document).on("click", '.save-btn', function(){
    UpdateInDb()
})

