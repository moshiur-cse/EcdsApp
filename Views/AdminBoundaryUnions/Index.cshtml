@model IEnumerable<EcdsApp.Models.RegionModels.AdminBoundaryUnion>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    /*.tab-card{
        max-height:50vh;
        overflow:auto;
    }*/
    tr{
        border-color:white;
    }
    .bx{
        font-size:0.75rem;
    }
    
    .dropdown-menu li>span{
        cursor:pointer;
        padding-right:5px;
        padding-left:5px;
    }
</style>


<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h3 class="display-6 mb-0">List of Union</h3>
                        <p class="card-title-desc">Union Details Information</p>
                        <a asp-action="Create" class="btn btn-info btn-rounded waves-effect waves-light w-lg">Add New Union</a>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive mt-2">
                            <!--Special Buttons-->
                            <div class="col-12 d-flex justify-content-center justify-content-md-end align-items-center my-3">
                                
                                <!--First Dropdown-->
                                <div class="dropdown me-3">
                                   <button class="btn btn-danger dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                                  No. of Rows <i class="bx bxs-down-arrow pt-1"></i>
                                   </button>
                                   <ul class="dropdown-menu" >
                                     <li class="my-2">
                                         <span onclick="LoadData(10)">Load 10 rows</span>
                                      </li>
                                      <li class="my-2">
                                         <span onclick="LoadData(25)">Load 25 rows</span>
                                      </li>
                                      <li class="my-2">
                                         <span onclick="LoadData(50)">Load 50 rows</span>
                                      </li>
                                       <li class="my-2">
                                         <span onclick="LoadFullData()">All rows</span>
                                      </li>
                                   </ul>
                                </div>
                                <!--End First Dropdown-->
                                <!--Second Dropdown-->
                                <div class="dropdown">
                                   <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                                   Column Customization
                                   </button>
                                   <ul class="dropdown-menu" >
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-1" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Upazila Name
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-2" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                           Union Name
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-3" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Union Name Bangla
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-4" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Municipality Name
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-5" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Municipality Geo Code
                                            </label>
                                         </div>
                                      </li>                                  
                                   </ul>
                                </div>
                                <!--End Second Dropdown-->
                            </div>
                            
                            <!--Special Buttons End-->
                            <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
                                <thead>
                                    <tr>
                                        <th>Action</th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.Upazila.UpazilaName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UnionName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UnionNameBangla)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.MunicipalityName)
                                        </th>
                                         <th>
                                            @Html.DisplayNameFor(model => model.MunicipalityGeoCode)
                                        </th>                                         
                                        <th>
                                            @Html.DisplayNameFor(model => model.SortingOrder)
                                        </th>
                                        
                                    </tr>
                                </thead>
                                <tbody class="maxvh-50 overflow-auto">
                                   
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @*<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModal">
  Launch demo modal
</button>*@
</div>


