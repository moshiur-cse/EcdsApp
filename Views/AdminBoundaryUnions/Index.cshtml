@section Scripts{
 
 <script type="text/javascript">
 let columnsToDownload=[]
 let totalData=@ViewBag.toData
 let arry=[]
 let geoCodes=[]
 let columns=[
            {
               data: null,
               render: function (data) {
                   return `<i role="button" class="bx bx-edit edit-btn fs-3 text-primary" d-ungcode="${data.unionGeoCode}" d-upgcode="${data.upazila.upazilaGeoCode}"></i>`;
               }      
            },
            { data: "upazila.upazilaName", autoWidth: true },
            { data: "unionName",  autoWidth: true },
            { data: "unionNameBangla", autoWidth: true },
            { data: "municipalityName", autoWidth: true },
            { data: "municipalityGeoCode", autoWidth: true },
            { data: "sortingOrder", autoWidth: true }            
        ]
//====data Table properties
let dTableProps ={
    dom: 'Bfrtip',
    processing: true,
    serverSide: true,
    filter:true,
    paging:true,
    fixedHeader: true,
    scrollY:true,
    ajax: {
            url: '@Url.Action("JqueryDataTableUnionList")',
            type: "POST",
            datatype: "json"
    },
    columns:columns,
    lengthChange: !1,
    pageLength: 10,
    buttons: [
        {
            extend: 'copyHtml5',
            exportOptions: {
                columns: [1,2,3,4,5]
            }
        },
        {
            extend: 'excelHtml5',
            exportOptions: {
                    columns: [1,2,3,4,5]
            }
        },
        {
            extend: 'pdfHtml5',
            exportOptions: {
                columns: [1,2,3,4,5]
            }
        },
        'colvis'
    ]
}
//=====data Table initialized
let table = $("#datatable-buttons").DataTable(dTableProps);
$(document).ready(function () {
    table.buttons().container().appendTo("#datatable-buttons_wrapper .col-md-6:eq(0)"), $(".dataTables_length select").addClass("form-select form-select-sm");
})

//====Update Information in the database
const SaveInDb =(e)=>{
    
    arry=[]
    for(let i=0;i<=5;i++){
        arry.push($("#d"+i).val())
    }

    $.post(
        '@Url.Action("Edit")',
        {            
            'adminBoundaryUnion.unionGeoCode':geoCodes[0],
            'adminBoundaryUnion.upazilaGeoCode':geoCodes[1],
            'adminBoundaryUnion.upazilaName':arry[0],
            'adminBoundaryUnion.unionName':arry[1],
            'adminBoundaryUnion.unionNameBangla':arry[2],
            'adminBoundaryUnion.municipalityName':arry[3],
            'adminBoundaryUnion.municipalityGeoCode':arry[4],
            'adminBoundaryUnion.sortingOrder':arry[5]
        },
        function(data){
           //=== response returned from server

           if(data=="success"){
                //=== updated successfully
                //=== update the row by removing input fields

                const tr=$($(e.target).parent()).parent()                
                const selected=tr.children()
                tr.html(`<td class="sorting_1 dtr-control"><i role="button" class="bx bx-edit edit-btn fs-3 text-primary" d-ungcode="${geoCodes[0]}" d-upgcode="${geoCodes[1]}"></i></td>`)                   
                for(let i=0;i < arry.length;i++){
                    tr.append(`<td>${arry[i]}</td>`)
                }

               //=== show success message
               window.Swal.fire({
                    icon: "success",
                    title: "Updated Successfully",
                    //confirmButtonText: 'Ok'
               })

              
           }            
        }
     );
}

//====custom input field insert
$(document).on("click", '.edit-btn', function(){
    arry=[]
    const td=$(this).parent()
    const allDataInRow=td.parent().children()
    for(let i=1;i<allDataInRow.length;i++){
       arry.push(allDataInRow[i].innerText)
    }
    geoCodes=[]
    geoCodes.push($(this).attr("d-ungcode"))
    geoCodes.push($(this).attr("d-upgcode"))
        
    
    $(td).parent().html(`
    <td class="sorting_1 dtr-control"><i role="button" class="text-primary bx bx-save save-btn fs-3"></i></i><i role="button" class="ms-3 bx bx-x cross-btn fs-3 text-primary"></i></td>
    <td><input type="text" id="d0" class="form-control" value="${arry[0]}"/></td>
    <td><input type="text" id="d1" class="form-control" value="${arry[1]}"/></td>
    <td><input type="text" id="d2" class="form-control" value="${arry[2]}"/></td>
    <td><input type="text" id="d3" class="form-control" value="${arry[3]}"/></td>
    <td><input type="text" id="d4" class="form-control" value="${arry[4]}"/></td>
    <td><input type="text" id="d5" class="form-control" value="${arry[5]}"/></td>`)
})

//==== Save Information click event handler

$(document).on("click", '.save-btn',(e)=>{
    SaveInDb(e)
})


//=== Remove input fields based on clicking x button
//=== and load the previous data

$(document).on("click", '.cross-btn', function(){
    
    const tr=$($(this).parent()).parent()
    console.log(tr.children())
    const selected=tr.children()
    tr.html(`<td class="sorting_1 dtr-control"><i role="button" class="bx bx-edit edit-btn fs-3 text-primary" d-ungcode="${geoCodes[0]}" d-upgcode="${geoCodes[1]}"></i></td>`)
    //console.log(selected.length)
    //console.log(arry.length)
    
    for(let i=0;i < arry.length;i++){
        tr.append(`<td>${arry[i]}</td>`)
    }
    
})

/* 
=================================================
      Multi select dropdown value change event
=================================================
 */

 
 $(document).on("change", ".form-check-input", function (){
     let selectedItems=$(".form-check-input")
     //console.log(selectedItems.length)     
     for(let i=0;i<selectedItems.length;i++){
         //console.log(selectedItems[i].checked)
        //======= the checkbox is checked
        if(selectedItems[i].checked){
            columnsToDownload.push(i+1)
        }
        
     }
     //console.log(columnsToDownload)
     //console.log(table.buttons())
     table.button().remove()
     table.button().remove()  
     table.button().remove()  
     table.button().remove()  
     table.button().add(0,{
        extend: 'copyHtml5',
        exportOptions: {
            columns: columnsToDownload
        }
            
     })
     table.button().add(1,{
        extend: 'excelHtml5',
        exportOptions: {
                columns: columnsToDownload
        }
        
     })
     table.button().add(2,{
        extend: 'pdfHtml5',
        exportOptions: {
            columns: columnsToDownload
        }
            
     })
     table.button().add(3,'colvis')
     
     //===reinitialize buttons to download only the selected columns    
     columnsToDownload=[]
     return false
    
 })

 //====Load Full Data
 const LoadFullData = async ()=>{
     jQuery("#busy-indicator").fadeIn(150);
     let x= await LoadAllRows()
     if(x=="completed")
        jQuery("#busy-indicator").fadeOut(150);
     
 }

 const LoadAllRows = async () => {

     return new Promise(resolve=>{
         table.page.len(totalData).draw()
         setTimeout(()=>{
             resolve("completed")
         },1000)
         
     })     
 }


 //=====Go to default pagination
 //====Load 10 rows

 const LoadData = (noOfRows)=>{
     jQuery("#busy-indicator").fadeIn(150);
     table.page.len(noOfRows).draw()
     jQuery("#busy-indicator").fadeOut(150);     
 }

 </script>
}


   