@model EcdsApp.Models.ThemeModels.SubTheme

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>SubTheme</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="SubThemeId" />
            <div class="form-group">
                <label asp-for="ThemeId" class="control-label"></label>
                <select asp-for="ThemeId" class="form-control" asp-items="ViewBag.ThemeId"></select>
                <span asp-validation-for="ThemeId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SubThemeName" class="control-label"></label>
                <input asp-for="SubThemeName" class="form-control" />
                <span asp-validation-for="SubThemeName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SubThemePath" class="control-label"></label>
                <input asp-for="SubThemePath" class="form-control" />
                <span asp-validation-for="SubThemePath" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
