@model IEnumerable<EcdsApp.Models.ThemeModels.SubTheme>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Themes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SubThemeName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SubThemePath)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Themes.ThemeName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SubThemeName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SubThemePath)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.SubThemeId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.SubThemeId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.SubThemeId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
