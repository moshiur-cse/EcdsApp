@model IEnumerable<EcdsApp.Models.AdminBoundaryDivision>

@{
	ViewData["Title"] = "Division List";
	Layout = "~/Views/Shared/_Layout.cshtml";
	
}
@section Styles{
	<style>
	tr {
		border-color: white;
	}

	.bx {
		font-size: 0.75rem;
	}

	.dropdown-menu li > span {
		cursor: pointer;
		padding-right: 5px;
		padding-left: 5px;
	}
	</style>
}

<div class="page-content">
	<div class="container-fluid">
		<div class="row">
			<div class="col-12">
				<div class="card">
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-center">
							<h4 class="display-6 mb-0 fs-4">List of Division</h4>
							<a asp-action="Create" class="btn btn-info btn-rounded waves-effect waves-light w-lg">Add New Division</a>
						</div>						
					</div>
				</div>
				<div class="card">
					<div class="card-body">
						<div class="table-responsive mt-2">
							<!--Special Buttons-->
							<div class="col-12 d-flex justify-content-center justify-content-md-end align-items-center my-3">

								<!--First Dropdown-->
								<div class="dropdown me-3">
									<button class="btn btn-danger dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
										No. of Rows <i class="bx bxs-down-arrow pt-1"></i>
									</button>
									<ul class="dropdown-menu">
										<li class="my-2">
											<span onclick="LoadData(10)">Load 10 rows</span>
										</li>
										<li class="my-2">
											<span onclick="LoadData(25)">Load 25 rows</span>
										</li>
										<li class="my-2">
											<span onclick="LoadData(50)">Load 50 rows</span>
										</li>
										@* <li class="my-2">
											<span onclick="LoadFullData()">All rows</span>
											</li>*@
									</ul>
								</div>
								<!--End First Dropdown-->
								<!--Second Dropdown-->
								<div class="dropdown">
									<button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
										Export Columns <i class="bx bxs-down-arrow pt-1"></i>
									</button>
									<ul class="dropdown-menu">
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Division Geo Code
												</label>
											</div>
										</li>
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Division Name
												</label>
											</div>
										</li>
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Division Name Bangla
												</label>
											</div>
										</li>
										<li>
											<div class="form-check">
												<input class="form-check-input" type="checkbox" value="" checked>
												<label class="form-check-label" for="flexCheckChecked">
													Sorting Order
												</label>
											</div>
										</li>
									</ul>
								</div>
								<!--End Second Dropdown-->
							</div>

							<!--Special Buttons End-->
							<table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
								<thead>
									 <tr>
                                        <th>Action</th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.DivisionGeoCode)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.DivisionName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.DivisionNameBangla)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.SortingOrder)
                                        </th>
                                    </tr>
								</thead>
								<tbody>
									@foreach (var item in Model)
									{
										<tr>
                                            <td>
                                                <i role="button" class="text-primary bx bx-edit font-size-20 edit-btn"></i>                                                
                                            </td>
                                            <td data-field="id">
                                                @Html.DisplayFor(modelItem => item.DivisionGeoCode)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.DivisionName)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.DivisionNameBangla)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.SortingOrder)
                                            </td>
                                        </tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts
{
<script type="text/javascript">
	let arry=[]
	let columnsToDownload=[]
	let tableProps={
		dom: 'Bfrtip',
		processing: true,
		filter:true,
		paging:true,
		fixedHeader: true,
		scrollY:true,
		//columns:columns,
		lengthChange: !1,
		pageLength: 10,
		buttons: [
			{
				extend: 'copyHtml5',
				title: 'Division Data',
				exportOptions: {
					columns: [1,2,3,4]
				}
			},
			{
				extend: 'excelHtml5',
				title: 'Division Data',
				exportOptions: {
						columns: [1,2,3,4]
				}
			},
			{
				extend: 'pdfHtml5',
				title: 'Division Data',
				exportOptions: {
					columns: [1,2,3,4]
				}
			},
			'colvis'
		]
	}
	let table=$("#datatable-buttons").DataTable(tableProps)

	//====add customized buttons in data table
	$(document).ready(function () {
		table.buttons().container().appendTo("#datatable-buttons_wrapper .col-md-6:eq(0)"), $(".dataTables_length select").addClass("form-select form-select-sm");
	});

	//=======================================
	//======= Change Columns to Download
	//=======================================

	 $(document).on("change", ".form-check-input", function (){
		 let selectedItems=$(".form-check-input")
		 //console.log(selectedItems.length)
		 for(let i=0;i<selectedItems.length;i++){
			 //console.log(selectedItems[i].checked)
			//======= the checkbox is checked
			if(selectedItems[i].checked){
				columnsToDownload.push(i+1)
			}

		 }
		 //console.log(columnsToDownload)

		 for(let i=0;i<4;i++){
			 table.button().remove()
		 }

		 table.button().add(0,{
			extend: 'copyHtml5',
			title: 'Division Data',
			exportOptions: {
				columns: columnsToDownload
			}

		 })
		 table.button().add(1,{
			extend: 'excelHtml5',
			title: 'Division Data',
			exportOptions: {
					columns: columnsToDownload
			}

		 })
		 table.button().add(2,{
			extend: 'pdfHtml5',
			title: 'Division Data',
			exportOptions: {
				columns: columnsToDownload
			}

		 })
		 table.button().add(3,'colvis')

		 //===reinitialize buttons to download only the selected columns
		 columnsToDownload=[]
		 return false
	})

	//========================================
	//=======Save, Edit, Delete Action
	//========================================


	//========================================
	//====custom input field insert
	//========================================
	$(document).on("click", '.edit-btn', function(e){
		table.columns().visible( true );
		table.columns.adjust().draw( false );
		arry=[]
		const td=$(this).parent()
		const allDataInRow=td.parent().children()
		for(let i=1;i<allDataInRow.length;i++){
		   arry.push(allDataInRow[i].innerText)
		}
		//console.log(arry)
		$(td).parent().html(`
		<td class="sorting_1 dtr-control"><i role="button" class="text-primary bx bx-save save-btn fs-3"></i></i><i role="button" class="ms-3 bx bx-x cross-btn fs-3 text-primary"></i></td>
		<td><input type="text" id="d0" class="form-control" value="${arry[0]}"/></td>
		<td><input type="text" id="d1" class="form-control" value="${arry[1]}"/></td>
		<td><input type="text" id="d2" class="form-control" value="${arry[2]}"/></td>
		<td><input type="text" id="d3" class="form-control" value="${arry[3]}"/></td>`)
	})

	//==========================================
	//==== Save Information click event handler
	//==========================================

	$(document).on("click", '.save-btn',(e)=>{
		SaveInDb(e)
	})

	//=====================================================
	//===== Remove input fields based on clicking x button
	//======= And load the previous data
	//=====================================================

	$(document).on("click", '.cross-btn', function(){

		const tr=$($(this).parent()).parent()
		//console.log(tr.children())
		const selected=tr.children()
		tr.html(`<td class="sorting_1 dtr-control"><i role="button" class="text-primary bx bx-edit font-size-20 edit-btn"></i></td>`)
		//console.log(selected.length)
		//console.log(arry)

		for(let i=0;i < arry.length;i++){
			tr.append(`<td>${arry[i]}</td>`)
		}

	})

	//=======================================
	//==== Update Information in the database
	//=======================================
	const SaveInDb =(e)=>{
		let oldArry=arry
		arry=[]
		for(let i=0;i<=3;i++){
			arry.push($("#d"+i).val())
		}

		$.post(
			'@Url.Action("Edit")',
			{
				'adminBoundaryDivision.divisionGeoCode':arry[0],
				'adminBoundaryDivision.divisionName':arry[1],
				'adminBoundaryDivision.divisionNameBangla':arry[2],
				'adminBoundaryDivision.sortingOrder':arry[3],

			},
			function(data){
				//=== response returned from server
				//console.log(data)
				const tr=$($(e.target).parent()).parent()
				if(data=="success"){
					//=== updated successfully
					//=== update the row by removing input fields					
					//const selected=tr.children()
					tr.html(`<td class="sorting_1 dtr-control"><i role="button" class="text-primary bx bx-edit font-size-20 edit-btn"></i></td>`)
					for(let i=0;i < arry.length;i++){
						tr.append(`<td>${arry[i]}</td>`)
					}

					//=== show success message
					window.Swal.fire({
						icon: "success",
						title: "Updated Successfully",
						//confirmButtonText: 'Ok'
					})
				}
				else{
					window.Swal.fire({
						icon: "error",
						title: data
						//confirmButtonText: 'Ok'
					})
					tr.html(`<td class="sorting_1 dtr-control"><i role="button" class="text-primary bx bx-edit font-size-20 edit-btn"></i></td>`)
					for(let i=0;i < oldArry.length;i++){
						tr.append(`<td>${oldArry[i]}</td>`)
					}
				}


			});
	}



	//========================================
	//=====Load Data based on required items
	//========================================

	const LoadData = (noOfRows)=>{
		jQuery("#busy-indicator").fadeIn(150);
		table.page.len(noOfRows).draw()
		jQuery("#busy-indicator").fadeOut(150);
	}

</script>
}
