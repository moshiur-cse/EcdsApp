@model IEnumerable<EcdsApp.Models.UserManage.ApplicationUser>
@{
    ViewData["Title"] = "Roles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body m-0">
                        <h3 class="display-6 mb-0">List of User</h3>
                        <p class="card-title-desc">User Details Information</p>
                        <a class="btn btn-info btn-rounded waves-effect waves-light w-lg">Add New User</a>
                    </div>
                </div>
                <div class="table-responsive mb-4">
                    <table class="table table-centered datatable nowrap table-card-list" style="border-collapse: collapse; border-spacing: 0 12px; width: 100%;">
                        <thead>
                            <tr class="bg-transparent">
                                <th>Id</th>
                                <th>UserName</th>
                                <th>Role</th>
                                <td>Email</td>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.UserName</td>
                                <td>@item.UserRole?.Name</td>
                                <td>@item.Email</td>
                                <td>
                                    @*<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm btn-rounded waves-effect waves-light w-sm">Edit</a>*@
                                     <a id="btnAssignRole" onclick="AssignRoleInUser('@item.Id')" class="btn btn-primary btn-sm btn-rounded waves-effect waves-light w-sm">Assign Role</a>
                                     <a class="btn btn-outline-dark px-4" asp-action="UpdateProfile" asp-route-userid="@item.Id">Edit</a>
                                     <a class="btn btn-outline-info navy-btn ml-2" asp-action="ViewProfile" asp-route-id="@item.Id">Details</a>
                                     <a class="btn btn-danger ml-2" id="@item.Id" data-name="@item.UserName" data-email="@item.Email" onclick="Delete()">Delete</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>

                    <!--  Large modal example -->
                    <div id="assignRoleModal" class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true" data-bs-backdrop="static">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content" style="margin-top: 190px">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="myLargeModalLabel">Edit User Role Information</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <input type="hidden" id="txtUserId" />

                                    <div class="row">
                                        <div class="col-md-12 mb-3">
                                            <label class="form-label required">Role Name</label>
                                            <select id="ddlRole" class="form-select" asp-items="@ViewBag.RoleList" required="" >
                                                <option value="">Select</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                                    <button id="btnSave" type="button" class="btn btn-success">Save</button>
                                </div>
                            </div><!-- /.modal-content -->
                        </div><!-- /.modal-dialog -->
                    </div><!-- /.modal -->

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script type="text/javascript">

 
        $(document).ready(function () {

            $(".datatable").DataTable(), $(".dataTables_length select").addClass("form-select form-select-sm");
            
        });
    
        function AssignRoleInUser(userId) {
            $('#txtUserId').val(userId);

            $("#assignRoleModal").modal("show");
        }

        $('#btnSave').click(function () {
            if ($('#ddlRole').val() === "") {
                window.Swal.fire({
                    icon: "error",
                    title: "Please Select a Role!",
                    showConfirmButton: false,
                    timer: 2000
                });
                return;
            }

            const postUrl = '@Url.Action("AssignRoleToUser", "UserAccessManage")';
            $.ajax({
                type: "POST",
                url: postUrl,
                accept: "application/json; charset=utf-8",
                data: { userId: $('#txtUserId').val(), roleId: $('#ddlRole').val()},
                before: $("#busy-indicator").fadeIn(150),
                success: function (result) {
                    if (result === "Success") {
                        window.Swal.fire({
                            icon: "success",
                            title: "Data Added Successfully!",
                            showConfirmButton: false,
                            timer: 2000
                        });
                        setTimeout(function () {
                            location.reload();
                        }, 2010);
                    } else {
                        window.Swal.fire({
                            icon: "error",
                            title: "Error Saving Data! Please try again",
                            showConfirmButton: false,
                            timer: 2500
                        });
                    }
                },
                error: function (xhr, ajaxOptions, thrownError) {
                    const errorMsg = xhr.responseText;
                    //debugger;
                    window.Swal.fire({
                        icon: "error",
                        title: errorMsg,
                        showConfirmButton: false,
                        timer: 25000
                    });
                },
                complete: $("#busy-indicator").fadeOut(150)
            });

        });

        const Delete = () => {

            let id = "#" + event.target.id;
            //console.log(id);
            let message = "You want to delete the user " + $(id).attr("data-name") + " ?";

            let res = window.confirm(message);
            id = id.slice(1);
            if (res) {

                $.ajax({
                    url: '@Url.Action("DeleteUser")',
                    data: { id: id },
                    success: function (res) {
                        if (res == "Succeeded") {
                            ShowDeleteMessage(Reload)
                        }
                    }
                });
            }
        }
        let succMsg = "@TempData["msg"]";
        if (succMsg != "") {
            //swal("Success", succMsg, "success");

            window.Swal.fire({
						icon: "success",
						title: succMsg,
						//confirmButtonText: 'Ok'
					})
        }
        
        const Reload = () => {
            setTimeout(function () { location.reload() }, 2000)
        }

        const ShowDeleteMessage = (callback) => {
              window.Swal.fire({
						icon: "success",
						title: "The User is deleted successfully !",
						//confirmButtonText: 'Ok'
					})
            callback()
        }
      
    </script>
}
