@model IEnumerable<IdentityRole>
@{
    ViewData["Title"] = "Roles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-body m-0">
                        <h3 class="display-6 mb-0">List of Role</h3>
                        <p class="card-title-desc">Role Details Information</p>
                        <a target="_blank" href="@Url.Action("AddRoleWithAccess", "UserAccessManage")" class="btn btn-info btn-rounded waves-effect waves-light w-lg">Add New Role</a>
                    </div>
                </div>
                <div class="table-responsive mb-4">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr class="bg-transparent">
                                <th class="text-center">Role Name</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">@item.Name</td>
                                <td class="text-center">
                                    <a class="btn btn-primary btn-sm btn-rounded waves-effect waves-light" style="margin-right: 20px;">Edit Name</a>
                                    <a target="_blank" href="@Url.Action("EditRoleWithAccess", "UserAccessManage", new { roleId = item.Id })" 
                                                class="btn btn-primary btn-sm btn-rounded waves-effect waves-light" style="margin-right: 20px;">Modify Permission</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>