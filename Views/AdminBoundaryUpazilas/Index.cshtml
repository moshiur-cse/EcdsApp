@model IEnumerable<EcdsApp.Models.AdminBoundaryUpazila>
@{
    ViewData["Title"] = "Upazila List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h3 class="display-6 mb-0">List of Upazila</h3>
                        <p class="card-title-desc">Upazila Details Information</p>
                        <a asp-action="Create" class="btn btn-info btn-rounded waves-effect waves-light w-lg">Add New Upazila</a>
                    </div>
                </div>
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive mt-2">
                            <!--Special Buttons-->
                            <div class="col-12 d-flex justify-content-center justify-content-md-end align-items-center my-3">
                                
                                <!--First Dropdown-->
                                <div class="dropdown me-3">
                                   <button class="btn btn-danger dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                                  No. of Rows <i class="bx bxs-down-arrow pt-1"></i>
                                   </button>
                                   <ul class="dropdown-menu" >
                                      <li class="my-2">
                                         <span onclick="LoadData(10)">Load 10 rows</span>
                                      </li>
                                      <li class="my-2">
                                         <span onclick="LoadData(25)">Load 25 rows</span>
                                      </li>
                                      <li class="my-2">
                                         <span onclick="LoadData(50)">Load 50 rows</span>
                                      </li>
                                       <li class="my-2">
                                         <span onclick="LoadFullData()">All rows</span>
                                      </li>
                                   </ul>
                                </div>
                                <!--End First Dropdown-->
                                <!--Second Dropdown-->
                                <div class="dropdown">
                                   <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                                   Column Customization
                                   </button>
                                   <ul class="dropdown-menu" >
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-1" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Upazila Name
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-2" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                           Union Name
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-3" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Union Name Bangla
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-4" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Municipality Name
                                            </label>
                                         </div>
                                      </li>
                                      <li>
                                         <div class="form-check">
                                            <input id="mld-5" class="form-check-input" type="checkbox" value="" checked>
                                            <label class="form-check-label" for="flexCheckChecked">
                                            Municipality Geo Code
                                            </label>
                                         </div>
                                      </li>                                  
                                   </ul>
                                </div>
                                <!--End Second Dropdown-->
                            </div>
                            
                            <!--Special Buttons End-->
                            <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
                                <thead>
                                    <tr>
                                        <th>Action</th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UpazilaGeoCode)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UpazilaName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.UpazilaNameBangla)
                                        </th>
                                        <th>
                                            District Name
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.SortingOrder)
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@item.UpazilaGeoCode" class="px-3 text-primary"><i class="uil-pen font-size-20"></i></a>
                                                @*<a asp-action="Delete" asp-route-id="@item.UpazilaGeoCode" class="btn btn-danger btn-rounded btn-soft-danger waves-effect waves-light">Delete</a>*@
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.UpazilaGeoCode)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.UpazilaName)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.UpazilaNameBangla)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.District.DistrictName)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.SortingOrder)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
<script type="text/javascript">
    $(document).ready(function () {
        $("#datatable-buttons").DataTable({
            lengthChange: !1,
            buttons: ["copy", "excel", "pdf", "colvis"]
        }).buttons().container().appendTo("#datatable-buttons_wrapper .col-md-6:eq(0)"), $(".dataTables_length select").addClass("form-select form-select-sm");
    });


    //====Load Full Data
    const LoadFullData = async ()=>{
        jQuery("#busy-indicator").fadeIn(150);
        let x= await LoadAllRows()
        if(x=="completed")
        jQuery("#busy-indicator").fadeOut(150);
     
    }

    const LoadAllRows = async () => {

        return new Promise(resolve=>{
            table.page.len(totalData).draw()
            setTimeout(()=>{
                resolve("completed")
            },1000)
         
        })     
    }


    //=====Go to default pagination
    //====Load 10 rows

    const LoadData = (noOfRows)=>{
        jQuery("#busy-indicator").fadeIn(150);
        table.page.len(noOfRows).draw()
        jQuery("#busy-indicator").fadeOut(150);     
    }

</script>
}
