@model EcdsApp.Models.TabularModels.TableInfo

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="page-content">
	<div class="container-fluid">
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-body">
            
            <h3>Are you sure you want to delete this?</h3>
            <div>
                
                <hr />
                <dl class="row">
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.SubThemes)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.SubThemes.SubThemeName)
                    </dd class>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.BoundaryInfo)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.BoundaryInfo.BoundaryName)
                    </dd class>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.TableName)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.TableName)
                    </dd>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.TableModelName)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.TableModelName)
                    </dd>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.DisplayName)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.DisplayName)
                    </dd>
                </dl>
    
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <input type="submit" value="Delete" class="btn btn-rounded btn-danger w-lg me-2" />
                    <a class="btn btn-rounded btn-info w-lg" asp-action="Index">Back to List</a>
                </form>
            </div>
           </div>
          </div>
        </div>
     </div>
    </div>
</div>